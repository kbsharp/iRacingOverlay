<Window x:Class="IRacingOverlay.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iRacing Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        MouseLeftButtonDown="OnDragWindow">

    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#F2F5FA" />
        <SolidColorBrush x:Key="TextMuted" Color="#8A93A6" />
        <SolidColorBrush x:Key="Accent" Color="#38BDF8" />

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
        </Style>

        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>
    </Window.Resources>

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <Border Width="248"
            Padding="16,12,16,14"
            CornerRadius="12"
            Background="#F0161923"
            BorderBrush="#2EFFFFFF"
            BorderThickness="1">
        <StackPanel>

            <DockPanel Margin="0,0,0,10">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center" DockPanel.Dock="Left">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#FBBF24" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="#4ADE80" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding ConnectionStatus}"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Style="{StaticResource Label}" />
                <TextBlock Text="FUEL"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="{StaticResource Accent}" />
            </DockPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="{Binding FuelLevelText}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" />
                <TextBlock Text="L"
                           Margin="6,0,0,6"
                           VerticalAlignment="Bottom"
                           FontSize="14"
                           Foreground="{StaticResource TextMuted}" />
            </StackPanel>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="AVG / LAP" Style="{StaticResource Label}" Margin="0,0,0,2" />
                    <TextBlock Text="{Binding AveragePerLapText}" Style="{StaticResource Value}" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="LAST LAP" Style="{StaticResource Label}" Margin="0,0,0,2" />
                    <TextBlock Text="{Binding LastLapText}" Style="{StaticResource Value}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="LAPS LEFT" Style="{StaticResource Label}" Margin="0,0,0,2" />
                    <TextBlock Text="{Binding LapsRemainingText}" Style="{StaticResource Value}" />
                </StackPanel>
            </Grid>

            <Border Height="1" Background="#22FFFFFF" Margin="0,0,0,10" />

            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="{Binding GearText}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource Accent}" />
                    <TextBlock Text="GEAR"
                               Margin="6,0,0,3"
                               VerticalAlignment="Bottom"
                               Style="{StaticResource Label}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding SpeedText}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Text="km/h"
                               Margin="6,0,0,3"
                               VerticalAlignment="Bottom"
                               Style="{StaticResource Label}" />
                </StackPanel>
            </DockPanel>

        </StackPanel>
    </Border>
</Window>
