<Window x:Class="IRacingOverlay.App.StandingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iRacing Overlay - Standings"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="24"
        Top="24"
        FontFamily="{StaticResource FontText}"
        MouseLeftButtonDown="OnDragWindow">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Margin="14">
        <!-- Widened by the position-change column's 26px rather than taking the
             space out of the driver name, which was already the first thing to
             ellipsize in a multiclass field. -->
        <Border Width="616"
                Padding="14,10,14,10"
                CornerRadius="6"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1"
                ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.6" Color="#000000" />
            </Border.Effect>

            <StackPanel>

                <!-- session strip (no widget-name label - the content identifies it).
                     Grid rather than DockPanel, for the reason documented at length
                     in RelativeWindow.xaml: the right-hand group must reserve its
                     width before the left tokens claim theirs, or it collapses and
                     overlaps them. This strip has more room to spare at 586px, but
                     it is the same structure and gets the same treatment so the two
                     can't drift apart. -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <!-- Auto, so the label takes exactly its own width and the
                                 tokens after it stay packed left. A star column (even a
                                 capped one) claims its whole width for a short label like
                                 "RACE" and shoves everything after it toward the middle
                                 of the strip. At 586px this widget has the room to spare,
                                 so it does not need the overflow handling the relative
                                 does. -->
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <!-- trailing spacer: keeps the tokens packed left. -->
                            <ColumnDefinition Width="*" MinWidth="0" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource Warning}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource Positive}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <!-- Session label stays quiet; the figure beside it is the
                             strip's headline. See RelativeWindow.xaml for why these
                             are two TextBlocks rather than one joined string. -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SessionTypeText}"
                                   Margin="9,0,0,0"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondary}" />
                        <TextBlock Grid.Column="2"
                                   Text="·"
                                   Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}"
                                   Visibility="{Binding HasSessionRemaining, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Grid.Column="3"
                                   Text="{Binding SessionRemainingText}"
                                   Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Typography.NumeralAlignment="Tabular"
                                   Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Grid.Column="4"
                                   Text="{Binding LapCounterText}"
                                   Margin="9,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Typography.NumeralAlignment="Tabular"
                                   Foreground="{StaticResource TextSecondary}" />
                        <!-- projected iRating. The wider widget has room for where the
                             rating actually lands, which the relative strip doesn't. -->
                        <Border Grid.Column="5"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                DataContext="{Binding IRating}"
                                Style="{StaticResource RatingDeltaChipBackground}"
                                Visibility="{Binding HasValue, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Arrow}" Style="{StaticResource RatingDeltaChipText}" />
                                <TextBlock Text="{Binding DeltaText}"
                                           Margin="3,0,0,0"
                                           Style="{StaticResource RatingDeltaChipText}" />
                                <TextBlock Text="{Binding Projected}"
                                           Margin="7,0,0,0"
                                           Style="{StaticResource ChipText}"
                                           Typography.NumeralAlignment="Tabular"
                                           Foreground="{StaticResource TextSecondary}" />
                            </StackPanel>
                        </Border>
                        <!-- Safety: corners per incident this session, arrowed against
                             the driver's own rolling baseline. Deliberately not a
                             projected SR figure - iRacing has never published the
                             CPI-to-SR conversion, so the direction is the most this
                             can honestly claim. The "CPI" label stays because the
                             number is meaningless unlabelled, unlike a lap time. -->
                        <Border Grid.Column="6"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                DataContext="{Binding Safety}"
                                Style="{StaticResource SafetyChipBackground}"
                                Visibility="{Binding HasValue, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Arrow}"
                                           Margin="0,0,3,0"
                                           Style="{StaticResource SafetyChipText}"
                                           Visibility="{Binding HasTrend, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{Binding CpiText}" Style="{StaticResource SafetyChipText}" />
                                <TextBlock Text="CPI"
                                           Margin="5,0,0,0"
                                           Style="{StaticResource ChipText}"
                                           Foreground="{StaticResource TextMuted}"
                                           Visibility="{Binding ShowCpiLabel, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </Border>
                        <TextBlock Grid.Column="7"
                                   Text="{Binding CarCountText}"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource Caption}" />
                    </Grid>

                    <TextBlock Grid.Column="1"
                               Text="{Binding ConnectionStatus}"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Style="{StaticResource Caption}" />
                </Grid>

                <!-- column captions, on a full-bleed header band so the table has a
                     visible head rather than a floating row of grey labels -->
                <Border Margin="-14,0,-14,3"
                        Padding="14,3,14,3"
                        Background="{StaticResource HeaderBand}"
                        BorderBrush="{StaticResource Separator}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="24" />
                            <!-- Places gained/lost. No caption: an arrow needs no
                                 heading, and there is no two-letter word for it
                                 that reads faster than the glyph itself. -->
                            <ColumnDefinition Width="26" />
                            <ColumnDefinition Width="40" />
                            <!-- Collapses to zero when the badges are switched off. -->
                            <ColumnDefinition Width="{Binding ManufacturerColumnWidth}" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="46" />
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="54" />
                            <ColumnDefinition Width="54" />
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="52" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="P" Style="{StaticResource Caption}" Margin="3,0,0,0" />
                        <TextBlock Grid.Column="4" Text="CAR" Style="{StaticResource Caption}" HorizontalAlignment="Center"
                                   Visibility="{Binding ShowManufacturerBadges, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Grid.Column="5" Text="DRIVER" Style="{StaticResource Caption}" />
                        <TextBlock Grid.Column="8" Text="INT" Style="{StaticResource Caption}" HorizontalAlignment="Right" Margin="0,0,6,0" />
                        <TextBlock Grid.Column="9" Text="GAP" Style="{StaticResource Caption}" HorizontalAlignment="Right" Margin="0,0,6,0" />
                        <TextBlock Grid.Column="10" Text="FASTEST" Style="{StaticResource Caption}" HorizontalAlignment="Right" Margin="0,0,6,0" />
                        <!-- 6px to match FASTEST: the last column sat flush against the
                             row edge, which only reads as wrong once the player row's
                             amber wash draws a visible boundary there. -->
                        <TextBlock Grid.Column="11" Text="LAST" Style="{StaticResource Caption}" HorizontalAlignment="Right" Margin="0,0,6,0" />
                    </Grid>
                </Border>

                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>

                                <!-- class-group banner -->
                                <Grid Height="22"
                                      Margin="0,5,0,1"
                                      Visibility="{Binding IsHeader, Converter={StaticResource BoolToVis}}">
                                    <Border Background="{Binding HeaderColorBrush}" Opacity="0.22" Margin="-14,0,-14,0" />
                                    <Border Background="{Binding HeaderColorBrush}" Width="5" HorizontalAlignment="Left" Margin="-14,0,0,0" />
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0,0,0">
                                        <!-- Class name-plate: a solid block of the sim's own class
                                             colour with dark text, like a number-board. The banner
                                             keeps its 0.22 wash, but at a squint that wash alone
                                             made three classes read as three similar dark tints -
                                             the solid plate is what makes multiclass grouping
                                             legible from the cockpit. -->
                                        <Border Background="{Binding HeaderColorBrush}"
                                                CornerRadius="2"
                                                Padding="5,0"
                                                Height="16"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ClassName}"
                                                       FontFamily="{StaticResource FontSmall}"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Top"
                                                       Margin="0,-0.5,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <!-- Light label by default; dark only when the
                                                             plate's fill is light enough to carry it
                                                             (RatingFormat.PrefersDarkText). Class colours
                                                             are series-defined, so a dark navy class would
                                                             otherwise swallow the label whole. -->
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HeaderPrefersDarkText}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource OnClassColor}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Text="{Binding ClassSofText}"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource Caption}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding ClassCountText}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource Caption}" />
                                </Grid>

                                <!-- car row -->
                                <Border Height="22"
                                        Visibility="{Binding IsRow, Converter={StaticResource BoolToVis}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="CornerRadius" Value="3" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAltRow}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource RowStripe}" />
                                                </DataTrigger>
                                                <!-- "You" row: warm wash + warm outer glow, so your own
                                                     line is findable at a glance in a full field. -->
                                                <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource PlayerHighlight}" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="16" ShadowDepth="0"
                                                                              Color="{StaticResource PlayerGlowColor}" Opacity="0.5" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid VerticalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="5" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="26" />
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="{Binding ManufacturerColumnWidth}" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="46" />
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="66" />
                                            <ColumnDefinition Width="52" />
                                        </Grid.ColumnDefinitions>

                                        <!-- full-height class colour bar, flush to the panel edge -->
                                        <Border Grid.Column="0" Width="5" Margin="-14,0,0,0"
                                                Background="{Binding ClassColorBrush}" />

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding PositionText}"
                                                   VerticalAlignment="Center"
                                                   Margin="3,0,0,0"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Typography.NumeralAlignment="Tabular"
                                                   Foreground="{StaticResource TextPrimary}" />

                                        <!-- Places gained/lost since the start. Blank for a car
                                             still on its starting position, so the column only
                                             speaks when something has actually happened. Green
                                             up / red down is the same pair the projected-iRating
                                             chip already uses for gain and loss. -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding PositionChangeText}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,0,5,0"
                                                   FontFamily="{StaticResource FontSmall}"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Typography.NumeralAlignment="Tabular">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PositionTrend}" Value="Up">
                                                            <Setter Property="Foreground" Value="{StaticResource Positive}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding PositionTrend}" Value="Down">
                                                            <Setter Property="Foreground" Value="{StaticResource Negative}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding CarNumberText}"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{StaticResource FontSmall}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Typography.NumeralAlignment="Tabular"
                                                   Foreground="{StaticResource TextMuted}" />

                                        <!-- Manufacturer badge: the vector mark where we have CC0 artwork,
                                             otherwise a short brand abbreviation in the same chip. -->
                                        <Grid Grid.Column="4"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Visibility="{Binding HasManufacturer, Converter={StaticResource BoolToVis}}">
                                            <!-- Wider than tall: several marks (McLaren's speedmark, the
                                                 Ford oval, the Cadillac crest) are very wide and flat, and
                                                 collapse to a hairline if fitted into a square box. -->
                                            <Path Data="{Binding ManufacturerMark}"
                                                  Fill="{StaticResource TextSecondary}"
                                                  Stretch="Uniform"
                                                  Width="22"
                                                  Height="14"
                                                  VerticalAlignment="Center" />
                                            <Border Visibility="{Binding UsesManufacturerText, Converter={StaticResource BoolToVis}}"
                                                    Style="{StaticResource ManufacturerBadgeBackground}">
                                                <TextBlock Text="{Binding ManufacturerText}"
                                                           Style="{StaticResource ManufacturerBadgeText}" />
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Column="5"
                                                   Text="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   TextTrimming="CharacterEllipsis">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding InPits}" Value="True">
                                                            <Setter Property="Opacity" Value="0.5" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Border Grid.Column="6" Style="{StaticResource LicenseBadgeBackground}">
                                            <TextBlock Text="{Binding License}"
                                                       Style="{StaticResource LicenseBadgeText}" />
                                        </Border>

                                        <Border Grid.Column="7" Style="{StaticResource IRatingBadgeBackground}">
                                            <TextBlock Text="{Binding IRatingText}"
                                                       Style="{StaticResource IRatingBadgeText}" />
                                        </Border>

                                        <!-- INT doubles as the pit indicator. A car sitting in
                                             its box has no meaningful interval to the car ahead,
                                             and this is the one number in the row it costs
                                             nothing to lose - the gap to the class leader, which
                                             is what tells you where they rejoin, stays put. The
                                             badge is the relative widget's, by the shared style. -->
                                        <Grid Grid.Column="8" Margin="0,0,6,0">
                                            <Border HorizontalAlignment="Right"
                                                    Style="{StaticResource PitBadgeBackground}"
                                                    Visibility="{Binding InPits, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="PIT" Style="{StaticResource PitBadgeText}" />
                                            </Border>
                                            <TextBlock Text="{Binding IntervalText}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMuted}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Timing}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding InPits}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>

                                        <TextBlock Grid.Column="9"
                                                   Text="{Binding GapText}"
                                                   Style="{StaticResource Timing}"
                                                   Margin="0,0,6,0"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextSecondary}" />

                                        <TextBlock Grid.Column="10"
                                                   Text="{Binding BestText}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,0,6,0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Typography.NumeralAlignment="Tabular">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSessionBest}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource FastestLap}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Grid.Column="11"
                                                   Text="{Binding LastDeltaText}"
                                                   Margin="0,0,6,0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource Timing}">
                                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LastDeltaIsSlower}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource Negative}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>
    </Grid>
</Window>
