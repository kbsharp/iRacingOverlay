<Window x:Class="IRacingOverlay.App.StandingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iRacing Overlay - Standings"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="24"
        Top="24"
        FontFamily="{StaticResource FontText}"
        MouseLeftButtonDown="OnDragWindow">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Margin="14">
        <Border Width="560"
                Padding="14,10,14,10"
                CornerRadius="3"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1"
                ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.6" Color="#000000" />
            </Border.Effect>

            <StackPanel>

                <!-- session strip (no widget-name label - the content identifies it) -->
                <DockPanel Margin="0,0,0,8">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" DockPanel.Dock="Left">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource Warning}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource Positive}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatus}"
                               DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Style="{StaticResource Caption}" />
                    <TextBlock Text="{Binding SessionText}"
                               Margin="9,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="Bold"
                               Typography.NumeralAlignment="Tabular"
                               Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Text="{Binding CarCountText}"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Style="{StaticResource Caption}" />
                </DockPanel>

                <!-- column captions, on a full-bleed header band so the table has a
                     visible head rather than a floating row of grey labels -->
                <Border Margin="-14,0,-14,3"
                        Padding="14,3,14,3"
                        Background="{StaticResource HeaderBand}"
                        BorderBrush="{StaticResource Separator}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="46" />
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="54" />
                            <ColumnDefinition Width="54" />
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="52" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="P" Style="{StaticResource Caption}" Margin="3,0,0,0" />
                        <TextBlock Grid.Column="3" Text="DRIVER" Style="{StaticResource Caption}" />
                        <TextBlock Grid.Column="6" Text="INT" Style="{StaticResource Caption}" HorizontalAlignment="Right" Margin="0,0,6,0" />
                        <TextBlock Grid.Column="7" Text="GAP" Style="{StaticResource Caption}" HorizontalAlignment="Right" Margin="0,0,6,0" />
                        <TextBlock Grid.Column="8" Text="FASTEST" Style="{StaticResource Caption}" HorizontalAlignment="Right" Margin="0,0,6,0" />
                        <TextBlock Grid.Column="9" Text="LAST" Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>

                                <!-- class-group banner -->
                                <Grid Height="22"
                                      Margin="0,5,0,1"
                                      Visibility="{Binding IsHeader, Converter={StaticResource BoolToVis}}">
                                    <Border Background="{Binding HeaderColorBrush}" Opacity="0.22" Margin="-14,0,-14,0" />
                                    <Border Background="{Binding HeaderColorBrush}" Width="5" HorizontalAlignment="Left" Margin="-14,0,0,0" />
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0,0,0">
                                        <TextBlock Text="{Binding ClassName}"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimary}" />
                                        <TextBlock Text="{Binding ClassSofText}"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource Caption}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding ClassCountText}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource Caption}" />
                                </Grid>

                                <!-- car row -->
                                <Border Height="22"
                                        Visibility="{Binding IsRow, Converter={StaticResource BoolToVis}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAltRow}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource RowStripe}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource PlayerHighlight}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid VerticalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="5" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="46" />
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="66" />
                                            <ColumnDefinition Width="52" />
                                        </Grid.ColumnDefinitions>

                                        <!-- full-height class colour bar, flush to the panel edge -->
                                        <Border Grid.Column="0" Width="5" Margin="-14,0,0,0"
                                                Background="{Binding ClassColorBrush}" />

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding PositionText}"
                                                   VerticalAlignment="Center"
                                                   Margin="3,0,0,0"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Typography.NumeralAlignment="Tabular"
                                                   Foreground="{StaticResource TextPrimary}" />

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding CarNumberText}"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{StaticResource FontSmall}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Typography.NumeralAlignment="Tabular"
                                                   Foreground="{StaticResource TextMuted}" />

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   TextTrimming="CharacterEllipsis">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding InPits}" Value="True">
                                                            <Setter Property="Opacity" Value="0.5" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Border Grid.Column="4"
                                                CornerRadius="2"
                                                Padding="4,1"
                                                Height="16"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource LicenseBadgeBackground}">
                                            <TextBlock Text="{Binding License}"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Style="{StaticResource LicenseBadgeText}" />
                                        </Border>

                                        <Border Grid.Column="5"
                                                CornerRadius="2"
                                                Padding="4,1"
                                                Height="16"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource IRatingBadgeBackground}">
                                            <TextBlock Text="{Binding IRatingText}"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Style="{StaticResource IRatingBadgeText}" />
                                        </Border>

                                        <TextBlock Grid.Column="6"
                                                   Text="{Binding IntervalText}"
                                                   Style="{StaticResource Timing}"
                                                   Margin="0,0,6,0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMuted}" />

                                        <TextBlock Grid.Column="7"
                                                   Text="{Binding GapText}"
                                                   Style="{StaticResource Timing}"
                                                   Margin="0,0,6,0"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextSecondary}" />

                                        <TextBlock Grid.Column="8"
                                                   Text="{Binding BestText}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,0,6,0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Typography.NumeralAlignment="Tabular">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSessionBest}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource FastestLap}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Grid.Column="9"
                                                   Text="{Binding LastDeltaText}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource Timing}">
                                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LastDeltaIsSlower}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource Negative}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>
    </Grid>
</Window>
