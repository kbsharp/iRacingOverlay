<Window x:Class="IRacingOverlay.App.FuelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iRacing Overlay - Fuel"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="600"
        Top="24"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        MouseLeftButtonDown="OnDragWindow">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Margin="16">
    <Border Width="330"
            Padding="18,12,18,13"
            CornerRadius="14"
            Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource PanelBorder}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.6" Color="#000000" />
        </Border.Effect>
        <Grid>
        <Border CornerRadius="14" Margin="-18,-12,-18,-13" Background="{StaticResource PanelSheen}" IsHitTestVisible="False" />
        <StackPanel>

            <!-- header -->
            <DockPanel Margin="0,0,0,8">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center" DockPanel.Dock="Left">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource Warning}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource Positive}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding ConnectionStatus}"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Style="{StaticResource Caption}" />
                <TextBlock Text="FUEL"
                           Margin="9,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="{StaticResource Accent}" />
            </DockPanel>

            <!-- current fuel level, big, with laps of running left -->
            <DockPanel Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding FuelLevelText}"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Text="L"
                               Margin="6,0,0,6"
                               VerticalAlignment="Bottom"
                               FontSize="14"
                               Foreground="{StaticResource TextMuted}" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <TextBlock Text="IN TANK" HorizontalAlignment="Right" Style="{StaticResource Caption}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,1,0,0">
                        <TextBlock Text="{Binding FuelLapsText}"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondary}" />
                        <TextBlock Text="laps"
                                   Margin="5,0,0,2"
                                   VerticalAlignment="Bottom"
                                   Style="{StaticResource Caption}" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>

            <!-- per-lap burn and race length -->
            <Grid Margin="0,0,0,9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="USED / LAP" Style="{StaticResource Caption}" Margin="0,0,0,2" />
                    <TextBlock Text="{Binding AveragePerLapText}" Style="{StaticResource Value}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="LAST LAP" Style="{StaticResource Caption}" Margin="0,0,0,2" />
                    <TextBlock Text="{Binding LastLapText}" Style="{StaticResource Value}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="RACE LAPS" Style="{StaticResource Caption}" Margin="0,0,0,2" />
                    <TextBlock Text="{Binding RaceLapsText}" Style="{StaticResource Value}" />
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{StaticResource Separator}" Margin="0,0,0,9" />

            <!-- fuel to finish + the headline margin badge -->
            <DockPanel Margin="0,0,0,8">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="TO FINISH" Style="{StaticResource Caption}" Margin="0,0,0,2" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ToFinishText}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Text="L needed"
                                   Margin="6,0,0,2"
                                   VerticalAlignment="Bottom"
                                   Style="{StaticResource Caption}" />
                    </StackPanel>
                </StackPanel>

                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        CornerRadius="8"
                        Padding="10,4"
                        Visibility="{Binding HasStrategy, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#264ADE9A" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WillFinish}" Value="False">
                                    <Setter Property="Background" Value="#26FF6B6B" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="{Binding MarginText}"
                                   HorizontalAlignment="Center"
                                   FontSize="17"
                                   FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource Positive}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WillFinish}" Value="False">
                                            <Setter Property="Foreground" Value="{StaticResource Negative}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding MarginLabel}"
                                   HorizontalAlignment="Center"
                                   FontSize="8"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondary}" />
                    </StackPanel>
                </Border>
            </DockPanel>

            <!-- next-stop actions -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="ADD" VerticalAlignment="Bottom" Margin="0,0,6,2" Style="{StaticResource Caption}" />
                    <TextBlock Text="{Binding AddFuelText}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Accent}" />
                    <TextBlock Text="L" Margin="3,0,0,2" VerticalAlignment="Bottom" Style="{StaticResource Caption}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="SAVE TO" VerticalAlignment="Bottom" Margin="0,0,6,2" Style="{StaticResource Caption}" />
                    <TextBlock Text="{Binding SaveTargetText}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondary}" />
                    <TextBlock Text="/lap" Margin="3,0,0,2" VerticalAlignment="Bottom" Style="{StaticResource Caption}" />
                </StackPanel>
            </Grid>

        </StackPanel>
        </Grid>
    </Border>
    <Border Height="1"
            Margin="1,1,1,0"
            CornerRadius="14,14,0,0"
            VerticalAlignment="Top"
            Background="{StaticResource PanelTopHighlight}"
            IsHitTestVisible="False" />
    </Grid>
</Window>
