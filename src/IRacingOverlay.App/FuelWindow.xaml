<Window x:Class="IRacingOverlay.App.FuelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:IRacingOverlay.App.Controls"
        Title="iRacing Overlay - Fuel"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="664"
        Top="24"
        FontFamily="{StaticResource FontText}"
        MouseLeftButtonDown="OnDragWindow">

    <!--
        Spacing here is deliberately on the same rhythm as the list widgets: a
        10px panel inset and 6px between blocks, rather than the 18/12 inset and
        8-10px gaps this panel used to carry. The old numbers made a widget with
        eight figures on it as tall as a twelve-car standings table.
    -->

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Margin="16">
    <Border Width="252"
            Padding="10,7,10,8"
            CornerRadius="6"
            Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource PanelBorder}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.6" Color="#000000" />
        </Border.Effect>
        <Grid>
        <Border CornerRadius="6" Margin="-10,-7,-10,-8" Background="{StaticResource PanelSheen}" IsHitTestVisible="False" />

        <!-- Pulses for the first minute of a Qualify/Race session - a reminder to
             double-check the loaded setup. Came across with the setup readout
             when that widget was folded in here; ShouldFlash is already gated on
             the user's ShowSetupReminder setting. -->
        <Border CornerRadius="6" Margin="-10,-7,-10,-8" IsHitTestVisible="False">
            <Border.Background>
                <SolidColorBrush Color="#00FFB03D" />
            </Border.Background>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShouldFlash}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard Name="FlashStoryboard">
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <!-- Targets this Border itself (the implicit target of a
                                             Style trigger); Storyboard.TargetName can't reach a
                                             sibling-named brush from inside a Style. -->
                                        <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#70FFB03D"
                                                        Duration="0:0:0.7" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="FlashStoryboard" />
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <StackPanel>

            <!-- header -->
            <DockPanel Margin="0,0,0,5">
                <Ellipse Width="7" Height="7" VerticalAlignment="Center" DockPanel.Dock="Left">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource Warning}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource Positive}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding ConnectionStatus}"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Style="{StaticResource Caption}" />
                <TextBlock Text="FUEL"
                           Margin="7,0,0,0"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource FontSmall}"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="{StaticResource Accent}" />
            </DockPanel>

            <!-- current fuel level, big, with laps of running left -->
            <DockPanel Margin="0,0,0,6">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding FuelLevelText}"
                               FontSize="26"
                               FontWeight="Bold"
                               Typography.NumeralAlignment="Tabular"
                               Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Text="{Binding FuelUnitLabel}"
                               Margin="4,0,0,4"
                               VerticalAlignment="Bottom"
                               FontSize="12"
                               Foreground="{StaticResource TextMuted}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding FuelLapsText}"
                               FontSize="16"
                               FontWeight="Bold"
                               Typography.NumeralAlignment="Tabular"
                               Foreground="{StaticResource TextSecondary}" />
                    <TextBlock Text="laps in tank"
                               Margin="4,0,0,2"
                               VerticalAlignment="Bottom"
                               Style="{StaticResource Caption}" />
                </StackPanel>
            </DockPanel>

            <!-- Tank gauge: fill = fuel against usable tank capacity, with a tick
                 at the fuel needed to finish. Fuel is the one quantity in the app
                 with a natural zero and a natural maximum, so it's the one that
                 reads faster as a bar than as digits - the timing widgets stay
                 number sheets on purpose.

                 Flat fill, 1px edge, no gloss: an instrument drawn in the panel
                 material rather than a borrowed pill gauge. Green/red is the same
                 pair as the margin badge below, so it needs no learning. Hidden
                 entirely when the sim hasn't reported a capacity. -->
            <Grid Height="6"
                  Margin="0,0,0,7"
                  Visibility="{Binding HasGauge, Converter={StaticResource BoolToVis}}">
                <Border CornerRadius="2"
                        Background="#1FFFFFFF"
                        BorderBrush="#2EFFFFFF"
                        BorderThickness="1" />

                <Grid Margin="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding GaugeFillWeight}" />
                        <ColumnDefinition Width="{Binding GaugeEmptyWeight}" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#CC33D689" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GaugeClearsTick}" Value="False">
                                        <Setter Property="Background" Value="#CCFF5C6C" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>

                <!-- The tick sits on top of the fill, so "level past the tick"
                     is legible as the bar having crossed it. -->
                <Grid Visibility="{Binding ShowGaugeTick, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding GaugeTickWeight}" />
                        <ColumnDefinition Width="{Binding GaugeTickRestWeight}" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="2"
                            HorizontalAlignment="Right"
                            Background="{StaticResource TextPrimary}" />
                </Grid>
            </Grid>

            <!-- per-lap burn and race length -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="USED / LAP" Style="{StaticResource Caption}" />
                    <TextBlock Text="{Binding AveragePerLapText}" Style="{StaticResource Value}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="LAST LAP" Style="{StaticResource Caption}" />
                    <TextBlock Text="{Binding LastLapText}" Style="{StaticResource Value}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="RACE LAPS" Style="{StaticResource Caption}" />
                    <TextBlock Text="{Binding RaceLapsText}" Style="{StaticResource Value}" />
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{StaticResource Separator}" Margin="0,0,0,6" />

            <!-- fuel to finish + the headline margin badge -->
            <DockPanel Margin="0,0,0,6">
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="TO FINISH" Style="{StaticResource Caption}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ToFinishText}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Typography.NumeralAlignment="Tabular"
                                   Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Text="{Binding FuelUnitLabel, StringFormat={}{0} needed}"
                                   Margin="4,0,0,2"
                                   VerticalAlignment="Bottom"
                                   Style="{StaticResource Caption}" />
                    </StackPanel>
                </StackPanel>

                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        CornerRadius="3"
                        Padding="7,2"
                        BorderThickness="1"
                        Visibility="{Binding HasStrategy, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#3D33D689" />
                            <Setter Property="BorderBrush" Value="#8A33D689" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WillFinish}" Value="False">
                                    <Setter Property="Background" Value="#3DFF5C6C" />
                                    <Setter Property="BorderBrush" Value="#8AFF5C6C" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding MarginText}"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Typography.NumeralAlignment="Tabular">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Positive}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WillFinish}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource Negative}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding MarginLabel}"
                                   Margin="5,0,0,1"
                                   VerticalAlignment="Bottom"
                                   Style="{StaticResource Caption}"
                                   Foreground="{StaticResource TextSecondary}" />
                    </StackPanel>
                </Border>
            </DockPanel>

            <!-- next-stop actions -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="ADD" VerticalAlignment="Bottom" Margin="0,0,5,1" Style="{StaticResource Caption}" />
                    <TextBlock Text="{Binding AddFuelText}"
                               FontSize="14"
                               FontWeight="Bold"
                               Typography.NumeralAlignment="Tabular"
                               Foreground="{StaticResource Accent}" />
                    <TextBlock Text="{Binding FuelUnitLabel}" Margin="3,0,0,1" VerticalAlignment="Bottom" Style="{StaticResource Caption}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="SAVE TO" VerticalAlignment="Bottom" Margin="0,0,5,1" Style="{StaticResource Caption}" />
                    <TextBlock Text="{Binding SaveTargetText}"
                               FontSize="14"
                               FontWeight="Bold"
                               Typography.NumeralAlignment="Tabular"
                               Foreground="{StaticResource TextSecondary}" />
                    <TextBlock Text="/lap" Margin="3,0,0,1" VerticalAlignment="Bottom" Style="{StaticResource Caption}" />
                </StackPanel>
            </Grid>

            <!-- Push-or-save: what the "SAVE TO" figure above actually costs.
                 The target on its own tells a driver what to burn but not whether
                 driving to it beats simply stopping - so both ways out are priced
                 in seconds, the one unit that lets them be compared at a glance.

                 The headline is the total rather than the per-lap rate on purpose:
                 the total is what weighs against a stop, and a bare rate with
                 nothing to compare it to is the failure that switched the
                 catch/defend column off. No verdict and no colour - two numbers in
                 the same unit already say which is cheaper, and a hue here would
                 collide with the green/red the margin badge owns. Absent while the
                 tank reaches the finish, and until the driver's own laps have said
                 what saving costs them. -->
            <StackPanel Visibility="{Binding HasFuelSave, Converter={StaticResource BoolToVis}}">
                <Border Height="1" Background="{StaticResource Separator}" Margin="0,6,0,6" />

                <DockPanel Margin="0,0,0,3">
                    <!-- "SAVING COSTS 7.1s", not "IF YOU SAVE 7.1s" - the parallel
                         with the pit line below was tempting, but it read at a
                         glance as saving seven seconds rather than spending them. -->
                    <TextBlock DockPanel.Dock="Left"
                               Text="SAVING COSTS"
                               VerticalAlignment="Bottom"
                               Margin="0,0,6,1"
                               Style="{StaticResource Caption}" />

                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding FuelSaveAlternativeText}"
                               VerticalAlignment="Bottom"
                               Margin="6,0,0,1"
                               Style="{StaticResource Caption}" />

                    <TextBlock Text="{Binding FuelSaveCostText}"
                               HorizontalAlignment="Left"
                               FontSize="16"
                               FontWeight="Bold"
                               Typography.NumeralAlignment="Tabular"
                               Foreground="{StaticResource TextPrimary}" />
                </DockPanel>

                <TextBlock Text="{Binding FuelSaveWorkingText}"
                           FontFamily="{StaticResource FontSmall}"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondary}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!-- Pit-exit projection: what stopping actually costs, which is the
                 decision being made. Everything above answers "can I reach the
                 finish"; this answers "and where does that leave me".

                 Written as a sentence on purpose. A bare "P4" among the other
                 figures here would be one more number to decode - the failure that
                 switched the catch/defend column off - so the position carries a
                 label, the gaps carry their unit and the car they're measured
                 against, and the learned pit loss is stated so the driver can see
                 what the answer was scaled by. Absent entirely outside a race, or
                 before enough stops have been seen to know the lane. -->
            <StackPanel Visibility="{Binding HasPitExit, Converter={StaticResource BoolToVis}}">
                <Border Height="1" Background="{StaticResource Separator}" Margin="0,6,0,6" />

                <DockPanel Margin="0,0,0,3">
                    <TextBlock DockPanel.Dock="Left"
                               Text="IF YOU PIT NOW"
                               VerticalAlignment="Bottom"
                               Margin="0,0,6,1"
                               Style="{StaticResource Caption}" />

                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding PitExitCostText}"
                               VerticalAlignment="Bottom"
                               Margin="6,0,0,1"
                               Style="{StaticResource Caption}" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding PitExitPositionText}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Typography.NumeralAlignment="Tabular"
                                   Foreground="{StaticResource TextPrimary}" />
                        <!-- Amber, not red: losing places to a stop you had to make
                             is the cost of racing, not a warning. Red here is the
                             fuel margin's, and it means "you do not finish". -->
                        <TextBlock Text="{Binding PitExitLostText}"
                                   Margin="5,0,0,1"
                                   VerticalAlignment="Bottom"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Typography.NumeralAlignment="Tabular"
                                   Foreground="{StaticResource Warning}" />
                    </StackPanel>
                </DockPanel>

                <TextBlock Text="{Binding PitExitNeighboursText}"
                           FontFamily="{StaticResource FontSmall}"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondary}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!-- Setup strip: what was a whole widget, reduced to the one line it
                 was ever worth - session chip, setup name, modified flag. -->
            <StackPanel Visibility="{Binding ShowSetupReminder, Converter={StaticResource BoolToVis}}">
                <Border Height="1" Background="{StaticResource Separator}" Margin="0,6,0,6" />
                <DockPanel>
                    <Border DockPanel.Dock="Left">
                        <Border.Style>
                            <!-- Same chip as the standings/relative badges: this had
                                 drifted to its own radius and padding. -->
                            <Style TargetType="Border" BasedOn="{StaticResource Chip}">
                                <Setter Property="Background" Value="#14FFFFFF" />
                                <Setter Property="BorderBrush" Value="#26FFFFFF" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRaceOrQualify}" Value="True">
                                        <Setter Property="Background" Value="#3DFFB03D" />
                                        <Setter Property="BorderBrush" Value="#8AFFB03D" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding SessionTypeText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource ChipText}">
                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRaceOrQualify}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource Warning}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <TextBlock DockPanel.Dock="Right"
                               Text="MOD"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource FontSmall}"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="{StaticResource Warning}"
                               Visibility="{Binding IsSetupModified, Converter={StaticResource BoolToVis}}" />

                    <TextBlock Text="{Binding SetupNameText}"
                               Margin="7,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"
                               TextTrimming="CharacterEllipsis" />
                </DockPanel>
            </StackPanel>

        </StackPanel>
        </Grid>
    </Border>
    <Border Height="1"
            Margin="2,1,2,0"
            CornerRadius="6,6,0,0"
            VerticalAlignment="Top"
            Background="{StaticResource PanelTopHighlight}"
            IsHitTestVisible="False" />

    <!-- Drag to scale this widget - see the WidgetResizeGrip style in App.xaml. -->
    <controls:WidgetResizeGrip Margin="0,0,-6,-6" />
    </Grid>
</Window>
