<Window x:Class="IRacingOverlay.App.DeltaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iRacing Overlay - Delta"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="600"
        Top="330"
        FontFamily="{StaticResource FontText}"
        MouseLeftButtonDown="OnDragWindow">

    <!--
        Same 10px inset and 6px block rhythm as the fuel panel. Narrow on purpose:
        this widget holds one number, and a panel wide enough for a table would
        make it read as more important than it is.
    -->

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Margin="16">
        <Border Width="176"
                Padding="10,7,10,8"
                CornerRadius="6"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.6" Color="#000000" />
            </Border.Effect>
            <Grid>
                <Border CornerRadius="6" Margin="-10,-7,-10,-8"
                        Background="{StaticResource PanelSheen}" IsHitTestVisible="False" />

                <StackPanel>

                    <!-- header -->
                    <DockPanel Margin="0,0,0,4">
                        <Ellipse Width="7" Height="7" VerticalAlignment="Center" DockPanel.Dock="Left">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource Warning}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource Positive}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ConnectionStatus}"
                                   DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource Caption}" />
                        <TextBlock Text="DELTA"
                                   Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource FontSmall}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Accent}" />
                    </DockPanel>

                    <!-- The number. Green faster, red slower, neutral inside the
                         deadband: the same green/red pair that already means
                         "gaining"/"losing" everywhere else in the app, so it needs
                         no learning. FontDisplay because at 30px that is the
                         optical size the family is drawn for. -->
                    <TextBlock Text="{Binding DeltaText}"
                               Margin="0,0,0,5"
                               HorizontalAlignment="Center"
                               FontFamily="{StaticResource FontDisplay}"
                               FontSize="30"
                               FontWeight="Bold"
                               Typography.NumeralAlignment="Tabular">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Tone}" Value="Neutral">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Tone}" Value="Faster">
                                        <Setter Property="Foreground" Value="{StaticResource Positive}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Tone}" Value="Slower">
                                        <Setter Property="Foreground" Value="{StaticResource Negative}" />
                                    </DataTrigger>
                                    <!-- Declared last so it wins: with no reading at
                                         all the tone is Neutral, but the placeholder
                                         must not be dressed as a live "on it" lap. -->
                                    <DataTrigger Binding="{Binding HasDelta}" Value="False">
                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Bar: grows from the centre, left for up, right for down,
                         full at one second either way. Same flat fill, 1px edge and
                         centre tick as the fuel gauge - a delta is the other
                         quantity in the app with a natural zero and a natural
                         scale, so it earns a bar for the same reason. -->
                    <Grid Height="7" Margin="0,0,0,6">
                        <Border CornerRadius="2"
                                Background="#1FFFFFFF"
                                BorderBrush="#2EFFFFFF"
                                BorderThickness="1" />

                        <Grid Margin="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0"
                                  Visibility="{Binding IsFaster, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding BarRestWeight}" />
                                    <ColumnDefinition Width="{Binding BarFillWeight}" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="1" CornerRadius="1" Background="#CC33D689" />
                            </Grid>

                            <Grid Grid.Column="1"
                                  Visibility="{Binding IsSlower, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding BarFillWeight}" />
                                    <ColumnDefinition Width="{Binding BarRestWeight}" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="1" Background="#CCFF5C6C" />
                            </Grid>
                        </Grid>

                        <!-- Zero, on top of the fill: without it the bar has no
                             anchor and a small delta reads as an empty bar. -->
                        <Border Width="2"
                                HorizontalAlignment="Center"
                                Background="{StaticResource TextPrimary}" />
                    </Grid>

                    <!-- What it's a delta of, and whether it's still live. -->
                    <DockPanel>
                        <!-- Deliberately colourless. Every hue in this app means one
                             thing, and "the number is a held one" is a statement
                             about the readout rather than about the lap - green and
                             red are already saying whether it was a good one. -->
                        <Border DockPanel.Dock="Right"
                                HorizontalAlignment="Right"
                                Background="#14FFFFFF"
                                BorderBrush="#26FFFFFF"
                                Style="{StaticResource Chip}"
                                Visibility="{Binding IsLapComplete, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="LAP"
                                       Style="{StaticResource ChipText}"
                                       FontSize="9"
                                       Foreground="{StaticResource TextMuted}" />
                        </Border>
                        <TextBlock Text="VS BEST" VerticalAlignment="Center" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding ReferenceText}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Typography.NumeralAlignment="Tabular"
                                   Foreground="{StaticResource TextSecondary}" />
                    </DockPanel>

                </StackPanel>
            </Grid>
        </Border>
        <Border Height="1"
                Margin="2,1,2,0"
                CornerRadius="6,6,0,0"
                VerticalAlignment="Top"
                Background="{StaticResource PanelTopHighlight}"
                IsHitTestVisible="False" />
    </Grid>
</Window>
