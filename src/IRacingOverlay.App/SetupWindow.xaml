<Window x:Class="IRacingOverlay.App.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iRacing Overlay - Setup"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="600"
        Top="300"
        FontFamily="{StaticResource FontText}"
        MouseLeftButtonDown="OnDragWindow">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Margin="16">
        <Border Width="260"
                Padding="16,12,16,13"
                CornerRadius="3"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.6" Color="#000000" />
            </Border.Effect>
            <Grid>
                <Border CornerRadius="3"
                        Margin="-16,-12,-16,-13"
                        Background="{StaticResource PanelSheen}"
                        IsHitTestVisible="False" />

                <!-- Pulses for the first minute of a Qualify/Race session - a
                     reminder to double-check the loaded setup. -->
                <Border CornerRadius="3"
                        Margin="-16,-12,-16,-13"
                        IsHitTestVisible="False">
                    <Border.Background>
                        <SolidColorBrush Color="#00FFB03D" />
                    </Border.Background>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShouldFlash}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Name="FlashStoryboard">
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <!-- Targets this Border itself (the implicit target of a
                                                     Style trigger); Storyboard.TargetName can't reach a
                                                     sibling-named brush from inside a Style. -->
                                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                To="#70FFB03D"
                                                                Duration="0:0:0.7" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="FlashStoryboard" />
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <StackPanel>

                    <DockPanel Margin="0,0,0,8">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" DockPanel.Dock="Left">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource Warning}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource Positive}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ConnectionStatus}"
                                   DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource Caption}" />
                        <TextBlock Text="SETUP"
                                   Margin="9,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Accent}" />
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                        <Border CornerRadius="5" Padding="6,2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#14FFFFFF" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRaceOrQualify}" Value="True">
                                            <Setter Property="Background" Value="#33FFB03D" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding SessionTypeText}" FontSize="10" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRaceOrQualify}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Warning}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="{Binding SetupNameText}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"
                               TextTrimming="CharacterEllipsis" />

                    <TextBlock Text="MODIFIED"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource Warning}"
                               Visibility="{Binding IsModified, Converter={StaticResource BoolToVis}}" />

                </StackPanel>
            </Grid>
        </Border>
        <Border Height="1"
                Margin="1,1,1,0"
                CornerRadius="3,3,0,0"
                VerticalAlignment="Top"
                Background="{StaticResource PanelTopHighlight}"
                IsHitTestVisible="False" />
    </Grid>
</Window>
