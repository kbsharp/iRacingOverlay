<Window x:Class="IRacingOverlay.App.WeatherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:IRacingOverlay.App.Controls"
        Title="iRacing Overlay - Weather"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="600"
        Top="610"
        FontFamily="{StaticResource FontText}"
        MouseLeftButtonDown="OnDragWindow">

    <!--
        A nowcast, not a forecast: iRacing publishes no future weather, so this
        states the transition already underway. Same 6px panel rhythm as the delta
        and fuel strips. The whole widget self-hides when the weather is flat -
        ShouldShow drives that - so a dry, stable race never shows it.
    -->

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Margin="16" Visibility="{Binding ShouldShow, Converter={StaticResource BoolToVis}}">
        <Border Width="196"
                Padding="10,7,10,8"
                CornerRadius="6"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.6" Color="#000000" />
            </Border.Effect>
            <Grid>
                <Border CornerRadius="6" Margin="-10,-7,-10,-8"
                        Background="{StaticResource PanelSheen}" IsHitTestVisible="False" />

                <StackPanel>

                    <!-- header -->
                    <DockPanel Margin="0,0,0,5">
                        <Ellipse Width="7" Height="7" VerticalAlignment="Center" DockPanel.Dock="Left">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource Warning}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource Positive}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ConnectionStatus}"
                                   DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource Caption}" />
                        <TextBlock Text="WEATHER"
                                   Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource FontSmall}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Accent}" />
                    </DockPanel>

                    <!-- The transition, the whole point of the strip. Amber for both
                         directions: the hue means "conditions changing, decide on
                         tyres" - which way is carried by the word and the arrow, not
                         by a second colour. -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <TextBlock Text="{Binding DirectionGlyph}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,5,0"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Warning}" />
                        <TextBlock Text="{Binding HeadlineText}"
                                   VerticalAlignment="Center"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Warning}" />
                    </StackPanel>

                    <!-- Current state, then the checkable referent underneath it. -->
                    <TextBlock Text="{Binding WetnessText}"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Text="{Binding ReferenceText}"
                               Margin="0,0,0,7"
                               Style="{StaticResource Caption}" />

                    <!-- Temps, quiet at the foot - current conditions the driver
                         already half-knows, present for completeness rather than as
                         the headline. A small arrow when the surface is moving. -->
                    <DockPanel>
                        <TextBlock Text="{Binding TempTrendGlyph}"
                                   DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}"
                                   Visibility="{Binding ShowTempTrend, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding AirTempText}"
                                   DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Typography.NumeralAlignment="Tabular"
                                   Foreground="{StaticResource TextSecondary}" />
                        <TextBlock Text="{Binding TrackTempText}"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Typography.NumeralAlignment="Tabular"
                                   Foreground="{StaticResource TextSecondary}" />
                    </DockPanel>

                </StackPanel>
            </Grid>
        </Border>
        <Border Height="1"
                Margin="2,1,2,0"
                CornerRadius="6,6,0,0"
                VerticalAlignment="Top"
                Background="{StaticResource PanelTopHighlight}"
                IsHitTestVisible="False" />

        <!-- Drag to scale this widget - see the WidgetResizeGrip style in App.xaml. -->
        <controls:WidgetResizeGrip Margin="0,0,-6,-6" />
    </Grid>
</Window>
