<Window x:Class="IRacingOverlay.App.DevControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iRacing Overlay - Dev Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="460"
        Top="140"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        MouseLeftButtonDown="OnDragWindow">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Close Panel" Click="OnClosePanel" />
            <MenuItem Header="Exit App" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Margin="16">
        <Border Width="228"
                Padding="16,12,16,14"
                CornerRadius="16"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.5" Color="#000000" />
            </Border.Effect>
            <StackPanel>

                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="DEV CONTROLS"
                               VerticalAlignment="Center"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource Accent}" />
                    <TextBlock Text="✕"
                               DockPanel.Dock="Right"
                               HorizontalAlignment="Right"
                               Cursor="Hand"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}"
                               MouseLeftButtonDown="OnCloseGlyphClicked" />
                </DockPanel>

                <TextBlock Text="FIELD" Style="{StaticResource Caption}" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="+ Add car"
                            Command="{Binding AddCarCommand}"
                            Style="{StaticResource DevButton}"
                            Margin="0,0,4,0" />
                    <Button Grid.Column="1"
                            Content="− Remove"
                            Command="{Binding RemoveCarCommand}"
                            Style="{StaticResource DevButton}" />
                </Grid>
                <TextBlock Text="{Binding CarCountText}"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           Margin="0,0,0,12" />

                <TextBlock Text="FUEL" Style="{StaticResource Caption}" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Grid.Column="0"
                            Content="− 5 L"
                            Command="{Binding DrainFuelCommand}"
                            Style="{StaticResource DevButton}"
                            Margin="0,0,4,4" />
                    <Button Grid.Row="0" Grid.Column="1"
                            Content="+ 5 L"
                            Command="{Binding AddFuelCommand}"
                            Style="{StaticResource DevButton}"
                            Margin="0,0,0,4" />
                    <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                            Content="Set critical (2 L)"
                            Command="{Binding SetCriticalFuelCommand}"
                            Style="{StaticResource DevButton}" />
                </Grid>

                <TextBlock Text="CONDITIONS" Style="{StaticResource Caption}" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="Cycle wetness"
                            Command="{Binding CycleWetnessCommand}"
                            Style="{StaticResource DevButton}"
                            Margin="0,0,4,0" />
                    <Button Grid.Column="1"
                            Content="+ Incident"
                            Command="{Binding AddIncidentCommand}"
                            Style="{StaticResource DevButton}" />
                </Grid>
                <TextBlock Text="{Binding WetnessText}"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           Margin="0,4,0,12" />

                <Button Content="Toggle player pit"
                        Command="{Binding TogglePlayerPitCommand}"
                        Style="{StaticResource DevButton}"
                        HorizontalAlignment="Stretch" />

            </StackPanel>
        </Border>
    </Grid>
</Window>
