<Application x:Class="IRacingOverlay.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <SolidColorBrush x:Key="TextPrimary" Color="#F2F5FA" />
        <SolidColorBrush x:Key="TextMuted" Color="#8A93A6" />
        <SolidColorBrush x:Key="Accent" Color="#38BDF8" />
        <SolidColorBrush x:Key="Warning" Color="#FBBF24" />
        <SolidColorBrush x:Key="LapAheadText" Color="#F87171" />
        <SolidColorBrush x:Key="LapBehindText" Color="#6FA8FF" />
        <SolidColorBrush x:Key="PanelBackground" Color="#F0161923" />
        <SolidColorBrush x:Key="PanelBorder" Color="#2EFFFFFF" />
        <SolidColorBrush x:Key="Separator" Color="#22FFFFFF" />

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
        </Style>

        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>
    </Application.Resources>
</Application>
