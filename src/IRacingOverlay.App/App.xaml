<Application x:Class="IRacingOverlay.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Segoe UI Variable ships three optical sizes and they are NOT
             interchangeable: Small is drawn for <=12px, Text for 12-28px, Display
             for headlines. Display at 11px renders spindly and tightly tracked -
             it reads as thin "terminal" text. Match the family to the size:
             captions/badges use Small, row and body text uses Text, only the big
             fuel readouts use Display.
             AllowsTransparency="True" also forces WPF off ClearType onto greyscale
             antialiasing, which thins stems further, so weights here run one step
             heavier than they would in a normal window. -->
        <FontFamily x:Key="FontSmall">Segoe UI Variable Small, Segoe UI</FontFamily>
        <FontFamily x:Key="FontText">Segoe UI Variable Text, Segoe UI</FontFamily>
        <FontFamily x:Key="FontDisplay">Segoe UI Variable Display, Segoe UI</FontFamily>

        <!-- Neutral graphite surface - deliberately NOT navy, so the panel material
             stops competing with the accent/badge colours that carry meaning. Near
             opaque (~94%): the track shows only faintly through. The top-to-bottom
             gradient is deliberately wider than a flat fill would be: a lighter,
             slightly cooler top falling to a deep bottom reads as a surface lit from
             above - that "material" cue is what stops the panel looking like a flat
             console rectangle. Still solid enough (RaceLab/LMU) not to be glassy. -->
        <LinearGradientBrush x:Key="PanelBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F0242A34" Offset="0" />
            <GradientStop Color="#F01A1D23" Offset="0.5" />
            <GradientStop Color="#F00E0F13" Offset="1" />
        </LinearGradientBrush>
        <!-- Faint glassy sheen concentrated at the very top of the panel, fading to
             nothing by a third of the way down - a specular highlight that lifts the
             surface. Overlaid full-bleed by the windows that opt in (Fuel/Setup). -->
        <LinearGradientBrush x:Key="PanelSheen" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#12FFFFFF" Offset="0" />
            <GradientStop Color="#05FFFFFF" Offset="0.35" />
            <GradientStop Color="#00FFFFFF" Offset="0.7" />
        </LinearGradientBrush>
        <!-- 1px lit hairline along the very top edge - the crisp "catch light" that
             sells the panel as a raised object rather than a printed rectangle. -->
        <SolidColorBrush x:Key="PanelTopHighlight" Color="#3DFFFFFF" />
        <!-- Panel edge is a top-lit gradient, not a flat hairline: bright along the
             top where light would catch it, dimmer down the sides - a subtle bevel
             that reads as a physical edge and keeps the widget a distinct object over
             busy track scenery. -->
        <LinearGradientBrush x:Key="PanelBorder" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#78FFFFFF" Offset="0" />
            <GradientStop Color="#4A2E3138" Offset="0.5" />
            <GradientStop Color="#382E3138" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="HeaderBand" Color="#1FFFFFFF" />
        <SolidColorBrush x:Key="Separator" Color="#38FFFFFF" />
        <SolidColorBrush x:Key="RowHover" Color="#14FFFFFF" />
        <!-- Alternating row shading (zebra) - very subtle so it reads as texture,
             not stripes. -->
        <SolidColorBrush x:Key="RowStripe" Color="#0DFFFFFF" />

        <SolidColorBrush x:Key="Accent" Color="#39A7FF" />
        <SolidColorBrush x:Key="AccentDim" Color="#4539A7FF" />
        <SolidColorBrush x:Key="Positive" Color="#33D689" />
        <SolidColorBrush x:Key="Negative" Color="#FF5C6C" />
        <SolidColorBrush x:Key="Warning" Color="#FFB03D" />
        <!-- Player row background wash - warm, not blue, so it reads distinctly
             from the accent colour used for badges/branding elsewhere. Stronger
             than a typical tint so it stays the clear "this is you" row even
             next to the now-colourful license/iRating badges and class bars. -->
        <SolidColorBrush x:Key="PlayerHighlight" Color="#5CFFB03D" />
        <SolidColorBrush x:Key="PlayerBorder" Color="#B0FFB03D" />
        <!-- The same amber as a bare Color, because DropShadowEffect.Color takes a
             Color and not a Brush - without this the player-row glow hue has to be
             retyped in every list widget, which is exactly how the two drift. -->
        <Color x:Key="PlayerGlowColor">#FFB03D</Color>

        <!-- Three clearly separated steps. The muted step was #7C8CAB, which at
             ~4:1 on this panel is where the greyness came from - captions read as
             dim noise rather than as a quiet tier of a hierarchy. -->
        <SolidColorBrush x:Key="TextPrimary" Color="#FBFCFF" />
        <SolidColorBrush x:Key="TextSecondary" Color="#D8E3F5" />
        <SolidColorBrush x:Key="TextMuted" Color="#98A9C6" />

        <SolidColorBrush x:Key="LapAheadText" Color="#FF7A85" />
        <SolidColorBrush x:Key="LapBehindText" Color="#6FB4FF" />

        <!-- Purple for the session's fastest lap in the standings, echoing
             iRacing's own timing colours. -->
        <SolidColorBrush x:Key="FastestLap" Color="#C08BFF" />

        <!-- iRacing's own license-class colours, so the badge reads instantly to
             anyone who races there. Reuses Negative/Positive/Accent where the
             tiers already line up (Rookie=red, B=green, A=blue). -->
        <SolidColorBrush x:Key="LicenseRookie" Color="#FF5C6C" />
        <SolidColorBrush x:Key="LicenseD" Color="#FF9640" />
        <SolidColorBrush x:Key="LicenseC" Color="#FFD84D" />
        <SolidColorBrush x:Key="LicenseB" Color="#33D689" />
        <SolidColorBrush x:Key="LicenseA" Color="#39A7FF" />
        <SolidColorBrush x:Key="LicensePro" Color="#E8B84D" />

        <!-- iRating bands - a distinct cool/vivid family so the badge is never
             confused with the license badge sitting next to it. -->
        <SolidColorBrush x:Key="IRatingLow" Color="#98A9C6" />
        <SolidColorBrush x:Key="IRatingMid" Color="#3FC7C0" />
        <SolidColorBrush x:Key="IRatingHigh" Color="#9B7BFA" />
        <SolidColorBrush x:Key="IRatingElite" Color="#E8579E" />

        <!-- Small uppercase field caption -->
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontSmall}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
        </Style>

        <!-- Secondary numeric value: the labelled figures in the fuel widget's
             metric columns. Sized to sit a clear step below the headline readout
             without competing with it - at the original 19 every figure in the
             panel was a headline, which is what made the widget sprawl next to
             the tightly-set list widgets. -->
        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontText}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <!-- Fixed-width digits: without this, proportional figures make the
                 numbers jitter as they tick and the columns read ragged. -->
            <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
        </Style>

        <!-- Timing figures in list rows (gap, interval, lap times). Tabular so the
             right-aligned columns line up digit-for-digit like a real timing
             screen. -->
        <Style x:Key="Timing" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontText}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
        </Style>

        <!-- Chip geometry, in ONE place. Every badge in the app (license, iRating,
             manufacturer, PIT, fuel status) is the same object at the same size, so
             the size lives here rather than being retyped per instance - that
             duplication is how the chips drifted apart in the first place.

             The vertical centring is the subtle part. A 10px line box is ~13.3 DIP
             tall but the caps/digits inside it are only ~7 DIP, and the font puts
             ~4 DIP of ascent gap above them against ~2.3 DIP of descent space below.
             Since these chips never contain a descender, that lower space is dead:
             centre the *line box* and the glyph lands visibly low (measured 10px
             above vs 4px below on a 2x render). ChipText therefore top-aligns the
             line box and lifts it a pixel, which centres the glyph rather than
             the box it sits in. -->
        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Height" Value="16" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ChipText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontSmall}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <!-- Half a DIP, not a whole one: the correction needed is genuinely
                 fractional, and -1 overshoots into 6-above/8-below. -->
            <Setter Property="Margin" Value="0,-0.5,0,0" />
        </Style>

        <!-- License badge chip: tinted background + a 1px edge in the same hue +
             vivid text, coloured by RelativeRowViewModel.LicenseTier. The edge is
             what makes it read as a chip: a bare tint fill at this size has no
             boundary and just looks like the text is sitting on a smudge. -->
        <Style x:Key="LicenseBadgeBackground" TargetType="Border" BasedOn="{StaticResource Chip}">
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="BorderBrush" Value="#26FFFFFF" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding LicenseTier}" Value="Rookie">
                    <Setter Property="Background" Value="#3DFF5C6C" />
                    <Setter Property="BorderBrush" Value="#8AFF5C6C" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LicenseTier}" Value="D">
                    <Setter Property="Background" Value="#3DFF9640" />
                    <Setter Property="BorderBrush" Value="#8AFF9640" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LicenseTier}" Value="C">
                    <Setter Property="Background" Value="#3DFFD84D" />
                    <Setter Property="BorderBrush" Value="#8AFFD84D" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LicenseTier}" Value="B">
                    <Setter Property="Background" Value="#3D33D689" />
                    <Setter Property="BorderBrush" Value="#8A33D689" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LicenseTier}" Value="A">
                    <Setter Property="Background" Value="#3D39A7FF" />
                    <Setter Property="BorderBrush" Value="#8A39A7FF" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LicenseTier}" Value="Pro">
                    <Setter Property="Background" Value="#3DE8B84D" />
                    <Setter Property="BorderBrush" Value="#8AE8B84D" />
                </DataTrigger>
                <!-- On the warm amber "you" row the translucent tint lets the row
                     colour bleed through and mud the chip; give player-row badges an
                     opaque dark backing so the hue edge + text stay legible. Declared
                     last so it wins the Background over the tier triggers above; the
                     tier BorderBrush (set alongside) still carries the hue. -->
                <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                    <Setter Property="Background" Value="#E61B1E25" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LicenseBadgeText" TargetType="TextBlock" BasedOn="{StaticResource ChipText}">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding LicenseTier}" Value="Rookie">
                    <Setter Property="Foreground" Value="{StaticResource LicenseRookie}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LicenseTier}" Value="D">
                    <Setter Property="Foreground" Value="{StaticResource LicenseD}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LicenseTier}" Value="C">
                    <Setter Property="Foreground" Value="{StaticResource LicenseC}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LicenseTier}" Value="B">
                    <Setter Property="Foreground" Value="{StaticResource LicenseB}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LicenseTier}" Value="A">
                    <Setter Property="Foreground" Value="{StaticResource LicenseA}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LicenseTier}" Value="Pro">
                    <Setter Property="Foreground" Value="{StaticResource LicensePro}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- iRating badge chip: same pattern, driven by IRatingTier -->
        <Style x:Key="IRatingBadgeBackground" TargetType="Border" BasedOn="{StaticResource Chip}">
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="BorderBrush" Value="#26FFFFFF" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IRatingTier}" Value="Mid">
                    <Setter Property="Background" Value="#3D3FC7C0" />
                    <Setter Property="BorderBrush" Value="#8A3FC7C0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IRatingTier}" Value="High">
                    <Setter Property="Background" Value="#3D9B7BFA" />
                    <Setter Property="BorderBrush" Value="#8A9B7BFA" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IRatingTier}" Value="Elite">
                    <Setter Property="Background" Value="#3DE8579E" />
                    <Setter Property="BorderBrush" Value="#8AE8579E" />
                </DataTrigger>
                <!-- See LicenseBadgeBackground: opaque dark backing on the "you" row
                     so the amber wash doesn't bleed through and kill the contrast. -->
                <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                    <Setter Property="Background" Value="#E61B1E25" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IRatingBadgeText" TargetType="TextBlock" BasedOn="{StaticResource ChipText}">
            <Setter Property="Foreground" Value="{StaticResource IRatingLow}" />
            <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IRatingTier}" Value="Mid">
                    <Setter Property="Foreground" Value="{StaticResource IRatingMid}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IRatingTier}" Value="High">
                    <Setter Property="Foreground" Value="{StaticResource IRatingHigh}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IRatingTier}" Value="Elite">
                    <Setter Property="Foreground" Value="{StaticResource IRatingElite}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Projected iRating chip (session strip). Green up / red down reuses the
             Positive/Negative pair already meaning "gaining" and "losing" elsewhere,
             so it needs no learning. Once the flag is out the chip fills in rather
             than changing hue: the result is the same news, just settled. -->
        <Style x:Key="RatingDeltaChipBackground" TargetType="Border" BasedOn="{StaticResource Chip}">
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="BorderBrush" Value="#26FFFFFF" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Trend}" Value="Up">
                    <Setter Property="BorderBrush" Value="#8A33D689" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Trend}" Value="Down">
                    <Setter Property="BorderBrush" Value="#8AFF5C6C" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsFinal}" Value="True" />
                        <Condition Binding="{Binding Trend}" Value="Up" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#3D33D689" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsFinal}" Value="True" />
                        <Condition Binding="{Binding Trend}" Value="Down" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#3DFF5C6C" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RatingDeltaChipText" TargetType="TextBlock" BasedOn="{StaticResource ChipText}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Trend}" Value="Up">
                    <Setter Property="Foreground" Value="{StaticResource Positive}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Trend}" Value="Down">
                    <Setter Property="Foreground" Value="{StaticResource Negative}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Manufacturer badge chip. Deliberately neutral/monochrome, not another
             coloured tier: the class bar, license and iRating chips already carry
             hue-as-meaning, so the manufacturer mark reads as iconography sitting in
             the panel material rather than yet another accent. This chip is the
             fallback for the makes with no vector mark; it holds a short brand
             abbreviation. -->
        <Style x:Key="ManufacturerBadgeBackground" TargetType="Border" BasedOn="{StaticResource Chip}">
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="BorderBrush" Value="#26FFFFFF" />
            <Style.Triggers>
                <!-- Opaque dark backing on the amber "you" row, matching the other
                     chips, so the row wash doesn't bleed through. -->
                <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                    <Setter Property="Background" Value="#E61B1E25" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ManufacturerBadgeText" TargetType="TextBlock" BasedOn="{StaticResource ChipText}">
            <!-- One step smaller than the other chips: these are 2-4 letter brand
                 abbreviations standing in for a vector mark, not a value to read. -->
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        </Style>

        <!-- Brake-disc mark for the brake-bias readout: a vented disc seen face-on
             with its caliper at the left. Drawn as a stroked geometry rather than a
             glyph so it stays crisp at 12px under greyscale AA, and so it doesn't
             depend on an icon font being installed. Sized for a 12x12 box. -->
        <Geometry x:Key="BrakeDiscIcon">
            M 1,6 A 5,5 0 1 0 11,6 A 5,5 0 1 0 1,6
            M 4.4,6 A 1.6,1.6 0 1 0 7.6,6 A 1.6,1.6 0 1 0 4.4,6
            M 1.6,3.1 L 0.3,3.1 L 0.3,8.9 L 1.6,8.9
        </Geometry>

        <Style x:Key="BrakeDiscMark" TargetType="Path">
            <Setter Property="Data" Value="{StaticResource BrakeDiscIcon}" />
            <Setter Property="Stroke" Value="{StaticResource TextMuted}" />
            <Setter Property="StrokeThickness" Value="1.1" />
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="Stretch" Value="None" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <!-- Flag chip. The one place in the overlay where hue is dictated entirely
             by the real world - a yellow flag must be yellow - so these are the
             marshals' own colours rather than the panel palette, with the personal
             flags (black, meatball, DQ) kept visually distinct from track flags. -->
        <Style x:Key="FlagChipBackground" TargetType="Border" BasedOn="{StaticResource Chip}">
            <Setter Property="Background" Value="{Binding FlagBackground}" />
            <Setter Property="BorderBrush" Value="{Binding FlagBorder}" />
        </Style>

        <Style x:Key="FlagChipText" TargetType="TextBlock" BasedOn="{StaticResource ChipText}">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Foreground" Value="{Binding FlagForeground}" />
        </Style>

        <!-- Pit-lane chip. Same geometry, amber-on-amber like the other tinted
             chips; kept as a named style so the relative and standings rows can't
             drift apart. -->
        <Style x:Key="PitBadgeBackground" TargetType="Border" BasedOn="{StaticResource Chip}">
            <Setter Property="Background" Value="#3DFFB03D" />
            <Setter Property="BorderBrush" Value="#8AFFB03D" />
        </Style>

        <Style x:Key="PitBadgeText" TargetType="TextBlock" BasedOn="{StaticResource ChipText}">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Foreground" Value="{StaticResource Warning}" />
        </Style>

        <!-- Flat button used by the dev control panel -->
        <Style x:Key="DevButton" TargetType="Button">
            <Setter Property="Background" Value="#1FFFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,7" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentDim}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Background" Value="#12FFFFFF" />
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
