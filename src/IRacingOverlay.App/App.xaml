<Application x:Class="IRacingOverlay.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Premium navy palette: a real lit-blue surface, not near-black -->
        <LinearGradientBrush x:Key="PanelBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EC212C46" Offset="0" />
            <GradientStop Color="#EC121A2E" Offset="1" />
        </LinearGradientBrush>
        <!-- Thin bright line along the top edge for a glassy, lit look -->
        <LinearGradientBrush x:Key="PanelTopHighlight" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#3DBFD8FF" Offset="0" />
            <GradientStop Color="#00BFD8FF" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="PanelBorder" Color="#5D6FA8E8" />
        <SolidColorBrush x:Key="HeaderBand" Color="#26FFFFFF" />
        <SolidColorBrush x:Key="Separator" Color="#22FFFFFF" />
        <SolidColorBrush x:Key="RowHover" Color="#14FFFFFF" />

        <SolidColorBrush x:Key="Accent" Color="#39A7FF" />
        <SolidColorBrush x:Key="AccentDim" Color="#4539A7FF" />
        <SolidColorBrush x:Key="Positive" Color="#33D689" />
        <SolidColorBrush x:Key="Negative" Color="#FF5C6C" />
        <SolidColorBrush x:Key="Warning" Color="#FFB03D" />

        <SolidColorBrush x:Key="TextPrimary" Color="#F6F9FF" />
        <SolidColorBrush x:Key="TextSecondary" Color="#C3D2EA" />
        <SolidColorBrush x:Key="TextMuted" Color="#7C8CAB" />

        <SolidColorBrush x:Key="LapAheadText" Color="#FF7A85" />
        <SolidColorBrush x:Key="LapBehindText" Color="#6FB4FF" />

        <!-- Small uppercase field caption -->
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
        </Style>

        <!-- Primary numeric value -->
        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>
    </Application.Resources>
</Application>
