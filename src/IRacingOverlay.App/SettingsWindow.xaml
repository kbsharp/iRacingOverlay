<Window x:Class="IRacingOverlay.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iRacing Overlay — Settings"
        Height="640" Width="520"
        MinHeight="420" MinWidth="460"
        WindowStartupLocation="CenterScreen"
        Background="#161A21"
        FontFamily="{StaticResource FontText}"
        FontSize="13"
        Foreground="{StaticResource TextPrimary}">

    <!--
        Deliberately a NORMAL window: standard chrome, a taskbar entry, and no
        AllowsTransparency. The overlay widgets are borderless and transparent
        because they sit over the sim, but that also costs them ClearType. This
        one is used alt-tabbed in the pits, so it gets proper text rendering and
        a title bar you can close.

        There is no OK/Apply: every control writes through immediately so the
        overlay reacts while you adjust it.
    -->

    <Window.Resources>
        <Style x:Key="SectionHeading" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontSmall}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="#1E242E" />
            <Setter Property="BorderBrush" Value="{StaticResource Separator}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontSmall}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,10" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Margin" Value="0,0,18,0" />
        </Style>

        <Style x:Key="TuningLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TuningValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18">
        <StackPanel>

            <!-- Widgets -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="WIDGETS" Style="{StaticResource SectionHeading}" />
                    <TextBlock Style="{StaticResource Hint}"
                               Text="Switch a widget off to hide it entirely. Click-through lets mouse clicks pass to the sim — a click-through widget can't be dragged, so come back here to turn it off again." />

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Widget" Style="{StaticResource Hint}" Margin="0" />
                        <TextBlock Grid.Column="1" Text="Scale" Style="{StaticResource Hint}" Margin="0" />
                        <TextBlock Grid.Column="2" Text="Click-through" Style="{StaticResource Hint}" Margin="0" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Widgets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsEnabled}"
                                              Content="{Binding DisplayName}" />

                                    <ComboBox Grid.Column="1"
                                              Width="72" HorizontalAlignment="Left"
                                              ItemsSource="{Binding ScaleOptions}"
                                              SelectedItem="{Binding Scale}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StringFormat={}{0:P0}}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <CheckBox Grid.Column="2" IsChecked="{Binding IsClickThrough}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Units -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="UNITS" Style="{StaticResource SectionHeading}" />

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Fuel" Style="{StaticResource TuningLabel}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton GroupName="Fuel" Content="Litres" IsChecked="{Binding FuelInLiters}" />
                            <RadioButton GroupName="Fuel" Content="Gallons" IsChecked="{Binding FuelInGallons}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Temperature" Style="{StaticResource TuningLabel}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton GroupName="Temp" Content="Celsius" IsChecked="{Binding TemperatureInCelsius}" />
                            <RadioButton GroupName="Temp" Content="Fahrenheit" IsChecked="{Binding TemperatureInFahrenheit}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Speed" Style="{StaticResource TuningLabel}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton GroupName="Speed" Content="km/h" IsChecked="{Binding SpeedInKph}" />
                            <RadioButton GroupName="Speed" Content="mph" IsChecked="{Binding SpeedInMph}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Style="{StaticResource Hint}" Margin="0,8,0,0"
                               Text="No widget shows a speed readout yet — the preference is here for when one does." />
                </StackPanel>
            </Border>

            <!-- Tuning -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="TUNING" Style="{StaticResource SectionHeading}" />

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="52" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Fuel safety margin" Style="{StaticResource TuningLabel}" />
                        <Slider Grid.Column="1" Minimum="0" Maximum="5" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Value="{Binding FuelSafetyMarginLaps}" />
                        <TextBlock Grid.Column="2" Style="{StaticResource TuningValue}"
                                   Text="{Binding FuelSafetyMarginLaps, StringFormat={}{0:0.0} lap}" />
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="52" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Setup reminder flash" Style="{StaticResource TuningLabel}" />
                        <Slider Grid.Column="1" Minimum="5" Maximum="300" TickFrequency="5" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Value="{Binding SetupFlashSeconds}" />
                        <TextBlock Grid.Column="2" Style="{StaticResource TuningValue}"
                                   Text="{Binding SetupFlashSeconds, StringFormat={}{0:0}s}" />
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="52" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Radar range" Style="{StaticResource TuningLabel}" />
                        <Slider Grid.Column="1" Minimum="15" Maximum="200" TickFrequency="5" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Value="{Binding RadarRangeMeters}" />
                        <TextBlock Grid.Column="2" Style="{StaticResource TuningValue}"
                                   Text="{Binding RadarRangeMeters, StringFormat={}{0:0} m}" />
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="52" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Relative cars each side" Style="{StaticResource TuningLabel}" />
                        <Slider Grid.Column="1" Minimum="1" Maximum="8" TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Value="{Binding RelativeSlotsPerSide}" />
                        <TextBlock Grid.Column="2" Style="{StaticResource TuningValue}"
                                   Text="{Binding RelativeSlotsPerSide}" />
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="52" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Standings cars per class" Style="{StaticResource TuningLabel}" />
                        <Slider Grid.Column="1" Minimum="5" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Value="{Binding StandingsMaxPerClass}" />
                        <TextBlock Grid.Column="2" Style="{StaticResource TuningValue}"
                                   Text="{Binding StandingsMaxPerClass}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- General -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="GENERAL" Style="{StaticResource SectionHeading}" />

                    <CheckBox Content="Start with Windows" IsChecked="{Binding RunAtStartup}" Margin="0,2,0,0" />
                    <TextBlock Style="{StaticResource Hint}"
                               Text="Adds a per-user startup entry. Has no effect for a portable or 'dotnet run' build." />

                    <Button Content="Reset widget positions"
                            Command="{Binding ResetLayoutCommand}"
                            Style="{StaticResource DevButton}"
                            HorizontalAlignment="Left" Padding="12,6" Margin="0,4,0,0" />
                    <TextBlock Style="{StaticResource Hint}" Margin="0,6,0,0"
                               Text="Forgets every saved position so each widget returns to its default corner on the next launch. The way back from a layout dragged somewhere unusable." />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
