<Window x:Class="IRacingOverlay.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="iRacing Overlay — Settings"
        Icon="Assets/app.ico"
        Height="820" Width="880"
        MinHeight="460" MinWidth="620"
        WindowStartupLocation="CenterScreen"
        Background="#12161C"
        FontFamily="{StaticResource FontText}"
        FontSize="13"
        Foreground="{StaticResource TextPrimary}">

    <!--
        Deliberately a NORMAL window: a taskbar entry, real resize/snap, and no
        AllowsTransparency. The overlay widgets are borderless and transparent
        because they sit over the sim, but that also costs them ClearType. This
        one is used alt-tabbed in the pits, so it gets proper text rendering.

        The caption is drawn by us rather than by Windows. WindowChrome (not
        WindowStyle="None") is what makes that possible without giving up snap,
        Aero drag or sane maximised bounds: it keeps the real window frame and
        just extends the client area up over the title bar, so the header below
        can wear the same panel material as the widgets. Anything clickable up
        there needs IsHitTestVisibleInChrome, or the chrome swallows the click
        and starts a window drag instead.

        There is no OK/Apply: every control writes through immediately so the
        overlay reacts while you adjust it.
    -->

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38" ResizeBorderThickness="6"
                            GlassFrameThickness="0" CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="SectionHeading" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontSmall}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <!-- Same material as a widget panel: the top-lit gradient, the 1px
             highlight along the top edge and the 6px corners. That is the whole
             point of the restyle - a settings card should look like a standings
             panel, not like a generic dialog groupbox. -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <!-- Minimise/close. Flat until hovered; close goes red on hover the way
             every Windows title bar does, because that one is muscle memory. -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1FFFFFFF" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#D8202B" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontSmall}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,10" />
        </Style>

        <!--
            Control templates. WPF's stock CheckBox/RadioButton/Slider/ComboBox
            render in the system's light chrome, which against this dark panel
            reads as a different application pasted into the window. These are
            deliberately scoped to this window's resources rather than App.xaml:
            the overlay widgets use none of these control types, and a set of
            implicit styles in the shared dictionary would be a trap for whoever
            adds the first one.

            Shared control palette: #262D38 fill, #46525F edge, Accent for the
            "on" state - the same accent the overlays reserve for branding, which
            here means "you have chosen this".
        -->

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <!-- Transparent background so the whole row is a hit target,
                             not just the 16px box. -->
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="Box" Width="16" Height="16" CornerRadius="3"
                                    Background="#262D38" BorderBrush="#46525F" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Path x:Name="Check" Visibility="Collapsed"
                                      Data="M 3.5,8 L 6.5,11 L 12.5,4.5"
                                      Stroke="#0B0E12" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#6C7C8C" />
                            </Trigger>
                            <!-- After the hover trigger so a checked box keeps its
                                 accent edge while the pointer is over it. -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource Accent}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Accent}" />
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Margin" Value="0,0,18,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Grid Width="16" Height="16" VerticalAlignment="Center">
                                <Ellipse x:Name="Ring" Fill="#262D38" Stroke="#46525F" StrokeThickness="1" />
                                <Ellipse x:Name="Dot" Width="7" Height="7" Visibility="Collapsed"
                                         Fill="{StaticResource Accent}" />
                            </Grid>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Ring" Property="Stroke" Value="#6C7C8C" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Ring" Property="Stroke" Value="{StaticResource Accent}" />
                                <Setter TargetName="Dot" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="20" Background="Transparent">
                            <Border Height="4" CornerRadius="2" Background="#2C3542"
                                    VerticalAlignment="Center" />
                            <Track x:Name="PART_Track">
                                <!-- The "filled" part left of the thumb is the decrease
                                     repeat button, retemplated to an accent bar. -->
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" VerticalAlignment="Center"
                                                        Background="{StaticResource Accent}" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="#F2F6FF" StrokeThickness="2"
                                                         Stroke="{StaticResource Accent}" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The ComboBox's closed-state box. Split out because a ComboBox template
             needs a ToggleButton child and it can't be declared inline twice. -->
        <Style x:Key="ComboToggle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" CornerRadius="4" Background="#262D38"
                                BorderBrush="#46525F" BorderThickness="1">
                            <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,9,0"
                                  Data="M 0,0 L 8,0 L 4,5 Z" Fill="{StaticResource TextMuted}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Style="{StaticResource ComboToggle}" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}" />
                            <!-- Not hit-test visible so clicks fall through to the
                                 toggle button underneath it. -->
                            <ContentPresenter Margin="10,0,26,0" VerticalAlignment="Center"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                            <Popup Placement="Bottom" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Margin="0,2,0,0" CornerRadius="4" Background="#1E242E"
                                        BorderBrush="#46525F" BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ItemsPresenter />
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource RowHover}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Minimal overlay-style scrollbar: no arrow buttons, no track chrome.
             Left stock, it's the one remaining strip of light grey on the window. -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0" Focusable="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0" Focusable="False" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Margin="2,0" CornerRadius="5" Background="#4A5766" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TuningLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TuningValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar. Wears the widget header band so the top of the window
             reads as part of the same app as the panels below it. -->
        <Border Grid.Row="0" Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource Separator}" BorderThickness="0,0,0,1">
            <Grid Height="38">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 1px lit edge along the very top, as on every widget panel. -->
                <Border Grid.ColumnSpan="3" Height="1" VerticalAlignment="Top"
                        Background="{StaticResource PanelTopHighlight}" />

                <Image Grid.Column="0" Source="Assets/app.ico" Width="16" Height="16"
                       Margin="12,0,0,0" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality" />

                <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"
                           FontFamily="{StaticResource FontSmall}" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextSecondary}"
                           Text="IRACING OVERLAY — SETTINGS" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,4,0"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource CaptionButton}" Content="&#xE921;"
                            ToolTip="Minimise" Click="MinimiseClick" />
                    <Button Style="{StaticResource CloseButton}" Content="&#xE8BB;"
                            ToolTip="Close" Click="CloseClick" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Two columns so the whole settings set fits without scrolling at the
             default size; the ScrollViewer is the fallback for a small window,
             and "Auto" means its bar is absent entirely when nothing overflows. -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,16,18,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="330" />
                    <ColumnDefinition Width="*" MinWidth="330" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,7,0">

            <!-- Widgets -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="WIDGETS" Style="{StaticResource SectionHeading}" />
                    <TextBlock Style="{StaticResource Hint}"
                               Text="Switch a widget off to hide it entirely. Click-through lets mouse clicks pass to the sim — a click-through widget can't be dragged, so come back here to turn it off again." />

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Widget" Style="{StaticResource Hint}" Margin="0" />
                        <TextBlock Grid.Column="1" Text="Scale" Style="{StaticResource Hint}" Margin="0" />
                        <TextBlock Grid.Column="2" Text="Click-through" Style="{StaticResource Hint}" Margin="0" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Widgets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsEnabled}"
                                              Content="{Binding DisplayName}" />

                                    <ComboBox Grid.Column="1"
                                              Width="72" HorizontalAlignment="Left"
                                              ItemsSource="{Binding ScaleOptions}"
                                              SelectedItem="{Binding Scale}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StringFormat={}{0:P0}}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <CheckBox Grid.Column="2" IsChecked="{Binding IsClickThrough}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Units -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="UNITS" Style="{StaticResource SectionHeading}" />

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Fuel" Style="{StaticResource TuningLabel}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton GroupName="Fuel" Content="Litres" IsChecked="{Binding FuelInLiters}" />
                            <RadioButton GroupName="Fuel" Content="Gallons" IsChecked="{Binding FuelInGallons}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Temperature" Style="{StaticResource TuningLabel}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton GroupName="Temp" Content="Celsius" IsChecked="{Binding TemperatureInCelsius}" />
                            <RadioButton GroupName="Temp" Content="Fahrenheit" IsChecked="{Binding TemperatureInFahrenheit}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Speed" Style="{StaticResource TuningLabel}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton GroupName="Speed" Content="km/h" IsChecked="{Binding SpeedInKph}" />
                            <RadioButton GroupName="Speed" Content="mph" IsChecked="{Binding SpeedInMph}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Style="{StaticResource Hint}" Margin="0,8,0,0"
                               Text="No widget shows a speed readout yet — the preference is here for when one does." />
                </StackPanel>
            </Border>

                </StackPanel>

                <StackPanel Grid.Column="1" Margin="7,0,0,0">

            <!-- Tuning -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="TUNING" Style="{StaticResource SectionHeading}" />

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="52" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Fuel safety margin" Style="{StaticResource TuningLabel}" />
                        <Slider Grid.Column="1" Minimum="0" Maximum="5" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Value="{Binding FuelSafetyMarginLaps}" />
                        <TextBlock Grid.Column="2" Style="{StaticResource TuningValue}"
                                   Text="{Binding FuelSafetyMarginLaps, StringFormat={}{0:0.0} lap}" />
                    </Grid>

                    <CheckBox Content="Show the setup reminder on the fuel widget"
                              IsChecked="{Binding ShowSetupReminder}" Margin="0,6,0,0" />
                    <TextBlock Style="{StaticResource Hint}"
                               Text="Adds a strip to the fuel widget with the loaded setup, and pulses the panel at the start of a Qualify or Race so you notice you're on the wrong one." />

                    <!-- Only has an effect while the checkbox above is on, hence the
                         binding that greys it out rather than a separate section. -->
                    <Grid Margin="0,4" IsEnabled="{Binding ShowSetupReminder}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="52" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Setup reminder flash" Style="{StaticResource TuningLabel}" />
                        <Slider Grid.Column="1" Minimum="5" Maximum="300" TickFrequency="5" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Value="{Binding SetupFlashSeconds}" />
                        <TextBlock Grid.Column="2" Style="{StaticResource TuningValue}"
                                   Text="{Binding SetupFlashSeconds, StringFormat={}{0:0}s}" />
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="52" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Radar range" Style="{StaticResource TuningLabel}" />
                        <Slider Grid.Column="1" Minimum="15" Maximum="200" TickFrequency="5" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Value="{Binding RadarRangeMeters}" />
                        <TextBlock Grid.Column="2" Style="{StaticResource TuningValue}"
                                   Text="{Binding RadarRangeMeters, StringFormat={}{0:0} m}" />
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="52" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Relative cars each side" Style="{StaticResource TuningLabel}" />
                        <Slider Grid.Column="1" Minimum="1" Maximum="8" TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Value="{Binding RelativeSlotsPerSide}" />
                        <TextBlock Grid.Column="2" Style="{StaticResource TuningValue}"
                                   Text="{Binding RelativeSlotsPerSide}" />
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="52" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Standings cars per class" Style="{StaticResource TuningLabel}" />
                        <Slider Grid.Column="1" Minimum="5" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Value="{Binding StandingsMaxPerClass}" />
                        <TextBlock Grid.Column="2" Style="{StaticResource TuningValue}"
                                   Text="{Binding StandingsMaxPerClass}" />
                    </Grid>

                    <CheckBox IsChecked="{Binding ShowManufacturerBadges}" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Manufacturer badges in the standings" VerticalAlignment="Center" />
                            <Border Background="{StaticResource Warning}" Opacity="0.85"
                                    CornerRadius="2" Padding="4,0" Margin="6,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="EXPERIMENTAL"
                                           FontFamily="{StaticResource FontSmall}"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="#101010" />
                            </Border>
                        </StackPanel>
                    </CheckBox>
                    <TextBlock Style="{StaticResource Hint}"
                               Text="Adds a car-maker column to the standings. Off by default: only some makes have a logo, so the rest fall back to a short text abbreviation (DAL, LIG, RAD, RUF) and the column reads as a mix." />

                    <CheckBox IsChecked="{Binding ShowPaceTrend}" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Catch/defend trend in the relative" VerticalAlignment="Center" />
                            <Border Background="{StaticResource Warning}" Opacity="0.85"
                                    CornerRadius="2" Padding="4,0" Margin="6,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="EXPERIMENTAL"
                                           FontFamily="{StaticResource FontSmall}"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="#101010" />
                            </Border>
                        </StackPanel>
                    </CheckBox>
                    <TextBlock Style="{StaticResource Hint}"
                               Text="Adds a column showing how fast each gap is closing or opening, and the laps until the battle lands. Off by default: the numbers are right but the column doesn't say what they are - a bare arrow and 0.2 has to be explained before it reads as seconds per lap." />
                </StackPanel>
            </Border>

            <!-- General -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="GENERAL" Style="{StaticResource SectionHeading}" />

                    <CheckBox Content="Start with Windows" IsChecked="{Binding RunAtStartup}" Margin="0,2,0,0" />
                    <TextBlock Style="{StaticResource Hint}"
                               Text="Adds a per-user startup entry. Has no effect for a portable or 'dotnet run' build." />

                    <CheckBox Content="Only show widgets while iRacing is running"
                              IsChecked="{Binding HideWhenSimClosed}" Margin="0,8,0,0" />
                    <TextBlock Style="{StaticResource Hint}"
                               Text="Widgets stay hidden until the sim connects and disappear again when it closes. Switch off to position them with iRacing shut." />

                    <Button Content="Reset widget positions"
                            Command="{Binding ResetLayoutCommand}"
                            Style="{StaticResource DevButton}"
                            HorizontalAlignment="Left" Padding="12,6" Margin="0,4,0,0" />
                    <TextBlock Style="{StaticResource Hint}" Margin="0,6,0,0"
                               Text="Forgets every saved position so each widget returns to its default corner on the next launch. The way back from a layout dragged somewhere unusable." />
                </StackPanel>
            </Border>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
