<Window x:Class="IRacingOverlay.App.TrackMapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:IRacingOverlay.App.ViewModels"
        Title="iRacing Overlay - Track Map"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="1180"
        Top="470"
        FontFamily="{StaticResource FontText}"
        MouseLeftButtonDown="OnDragWindow">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Margin="16">
        <Border Padding="10,7,10,10"
                CornerRadius="6"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.6" Color="#000000" />
            </Border.Effect>
            <Grid>
                <Border CornerRadius="6" Margin="-10,-7,-10,-10"
                        Background="{StaticResource PanelSheen}" IsHitTestVisible="False" />

                <StackPanel>

                    <!-- header -->
                    <DockPanel Margin="0,0,0,6">
                        <Ellipse Width="7" Height="7" VerticalAlignment="Center" DockPanel.Dock="Left">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource Warning}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource Positive}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ConnectionStatus}"
                                   DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource Caption}" />
                        <TextBlock Text="TRACK"
                                   Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource FontSmall}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Accent}" />
                    </DockPanel>

                    <Grid Width="{x:Static vm:TrackMapLayout.CanvasSize}"
                          Height="{x:Static vm:TrackMapLayout.CanvasSize}">

                        <!-- ===================== The circuit ===================== -->
                        <!-- Drawn twice: a dark casing, then the tarmac ribbon inside
                             it. The casing is what makes it read as a track rather
                             than a wire - it gives the ribbon an edge, so where the
                             lap doubles back on itself the two passes stay separate
                             instead of merging into one grey smudge. -->
                        <Canvas Visibility="{Binding HasOutline, Converter={StaticResource BoolToVis}}">
                            <Polyline Points="{Binding OutlinePoints}"
                                      Stroke="#CC10141A"
                                      StrokeThickness="{x:Static vm:TrackMapLayout.CasingThickness}"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            <Polyline Points="{Binding OutlinePoints}"
                                      Stroke="#FF5A6572"
                                      StrokeThickness="{x:Static vm:TrackMapLayout.TrackThickness}"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />

                            <!-- Start/finish. The one piece of furniture: it says
                                 where the lap begins, which is what turns a closed
                                 loop into this circuit. -->
                            <Line X1="{Binding StartLineFrom.X}" Y1="{Binding StartLineFrom.Y}"
                                  X2="{Binding StartLineTo.X}" Y2="{Binding StartLineTo.Y}"
                                  Stroke="{StaticResource TextPrimary}"
                                  StrokeThickness="2" />
                        </Canvas>

                        <!-- ======================== The field ======================== -->
                        <!-- Class colour and nothing else: a dot per car, sized alike,
                             so the shape of the field is what the eye picks up. Your
                             own car is a size up with a warm ring - the same "this is
                             you" the standings and relative rows use. -->
                        <ItemsControl ItemsSource="{Binding Cars}"
                                      Width="{x:Static vm:TrackMapLayout.CanvasSize}"
                                      Height="{x:Static vm:TrackMapLayout.CanvasSize}"
                                      Visibility="{Binding HasOutline, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}" />
                                    <Setter Property="Canvas.Top" Value="{Binding CanvasTop}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="{Binding Size}" Height="{Binding Size}"
                                          Opacity="{Binding Opacity}">
                                        <!-- A dark halo rather than a hard border, so a
                                             pale class colour stays legible where it
                                             crosses the track's own edge. -->
                                        <Ellipse Fill="{Binding Fill}">
                                            <Ellipse.Effect>
                                                <DropShadowEffect BlurRadius="5" ShadowDepth="0"
                                                                  Opacity="0.9" Color="#000000" />
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <Ellipse Stroke="{StaticResource PlayerBorder}"
                                                 StrokeThickness="2"
                                                 Visibility="{Binding IsPlayer,
                                                              Converter={StaticResource BoolToVis}}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- ==================== Still learning ==================== -->
                        <!-- The first lap has no circuit to draw. Say so, with the
                             progress: an empty panel reads as a broken widget, where
                             a number that climbs reads as one doing its job. -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding IsMapping, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding MappingText}"
                                       HorizontalAlignment="Center"
                                       FontFamily="{StaticResource FontDisplay}"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Typography.NumeralAlignment="Tabular"
                                       Foreground="{StaticResource TextSecondary}" />
                            <TextBlock Text="LEARNING TRACK"
                                       Margin="0,2,0,0"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource Caption}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
        <Border Height="1"
                Margin="2,1,2,0"
                CornerRadius="6,6,0,0"
                VerticalAlignment="Top"
                Background="{StaticResource PanelTopHighlight}"
                IsHitTestVisible="False" />
    </Grid>
</Window>
