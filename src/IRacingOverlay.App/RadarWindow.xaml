<Window x:Class="IRacingOverlay.App.RadarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:IRacingOverlay.App.ViewModels"
        Title="iRacing Overlay - Radar"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="600"
        Top="470"
        FontFamily="{StaticResource FontText}"
        MouseLeftButtonDown="OnDragWindow">

    <Window.Resources>
        <!-- Fallback proximity zone (first lap, before the track is mapped). -->
        <Style x:Key="FallbackZone" TargetType="Border">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="64" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Background" Value="#14FFFFFF" />
        </Style>
    </Window.Resources>

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <!-- The whole widget hides when nobody is near; ShouldShow drives that. -->
    <Grid Margin="14"
          Visibility="{Binding ShouldShow, Converter={StaticResource BoolToVis}}">
        <Border Padding="10"
                CornerRadius="6"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.6" Color="#000000" />
            </Border.Effect>

            <Grid>
                <!-- ================= Positional radar (track learned) ================= -->
                <Grid Width="{x:Static vm:RadarLayout.CanvasWidth}"
                      Height="{x:Static vm:RadarLayout.CanvasHeight}"
                      Visibility="{Binding ShowRadar, Converter={StaticResource BoolToVis}}">

                    <!-- Scope field -->
                    <Border CornerRadius="3" Background="#B30A0E14" BorderBrush="#26FFFFFF" BorderThickness="1" />

                    <!-- Faint axes through the player, for orientation -->
                    <Border Width="1" HorizontalAlignment="Center" Background="#18FFFFFF" />
                    <Border Height="1" VerticalAlignment="Center" Background="#18FFFFFF" />

                    <!-- Other cars, absolutely positioned on a Canvas by the view model -->
                    <ItemsControl ItemsSource="{Binding Blips}"
                                  Width="{x:Static vm:RadarLayout.CanvasWidth}"
                                  Height="{x:Static vm:RadarLayout.CanvasHeight}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}" />
                                <Setter Property="Canvas.Top" Value="{Binding CanvasTop}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="{x:Static vm:RadarLayout.BlipWidth}"
                                        Height="{x:Static vm:RadarLayout.BlipHeight}"
                                        CornerRadius="2"
                                        Background="{Binding Fill}"
                                        BorderBrush="#40000000"
                                        BorderThickness="1"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <RotateTransform Angle="{Binding AngleDegrees}" />
                                    </Border.RenderTransform>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Player car, always dead centre facing up -->
                    <Border Width="{x:Static vm:RadarLayout.BlipWidth}"
                            Height="{x:Static vm:RadarLayout.BlipHeight}"
                            CornerRadius="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{StaticResource TextPrimary}">
                        <Border Width="7"
                                Height="5"
                                Margin="0,3,0,0"
                                CornerRadius="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Background="{StaticResource Accent}" />
                    </Border>
                </Grid>

                <!-- ================= Spotter fallback (first lap) ================= -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding ShowFallback, Converter={StaticResource BoolToVis}}">
                    <Border Margin="0,0,6,0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource FallbackZone}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasCarLeft}" Value="True">
                                        <Setter Property="Background" Value="#B0FF5C6C" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <Border Width="20"
                            Height="52"
                            CornerRadius="2"
                            Background="{StaticResource TextMuted}"
                            Opacity="0.9" />
                    <Border Margin="6,0,0,0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource FallbackZone}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasCarRight}" Value="True">
                                        <Setter Property="Background" Value="#B0FF5C6C" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </StackPanel>

                <!-- ================= Placeholder (pre-session) ================= -->
                <TextBlock Text="radar"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{StaticResource TextMuted}"
                           Visibility="{Binding IsWaitingForData, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>
    </Grid>
</Window>
