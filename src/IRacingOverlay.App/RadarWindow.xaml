<Window x:Class="IRacingOverlay.App.RadarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:IRacingOverlay.App.ViewModels"
        Title="iRacing Overlay - Radar"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="600"
        Top="470"
        FontFamily="{StaticResource FontText}"
        MouseLeftButtonDown="OnDragWindow">

    <Window.Resources>
        <!-- The proximity glow: hottest at the inner edge (your door), falling away
             outward. Painted twice, mirrored, so each side reads independently. -->
        <RadialGradientBrush x:Key="DangerGlow" GradientOrigin="0.5,0.5" Center="0.5,0.5"
                             RadiusX="0.5" RadiusY="0.5">
            <GradientStop Offset="0.0" Color="#FFFF2A2A" />
            <GradientStop Offset="0.45" Color="#B8FF1F1F" />
            <GradientStop Offset="1.0" Color="#00FF0000" />
        </RadialGradientBrush>
    </Window.Resources>

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <!-- The whole widget hides when nobody is near; ShouldShow drives that.
         Deliberately chrome-free - no panel, no border, no scope field. The radar
         reads as marks floating on the track, so it costs the driver nothing when
         the mirrors are already busy; only the glow is meant to catch the eye. -->
    <Grid Margin="14"
          Visibility="{Binding ShouldShow, Converter={StaticResource BoolToVis}}">
        <Grid Width="{x:Static vm:RadarLayout.CanvasWidth}"
              Height="{x:Static vm:RadarLayout.CanvasHeight}">

            <!-- Proximity glows: tight blobs sitting just off each door, not a wash
                 over the whole widget - they have to read in peripheral vision without
                 hiding the track behind them. -->
            <Ellipse Width="78" Height="104"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Margin="-96,0,0,0"
                     IsHitTestVisible="False"
                     Fill="{StaticResource DangerGlow}"
                     Opacity="{Binding LeftDanger}" />
            <Ellipse Width="78" Height="104"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Margin="96,0,0,0"
                     IsHitTestVisible="False"
                     Fill="{StaticResource DangerGlow}"
                     Opacity="{Binding RightDanger}" />

            <!-- ================= Positional radar (track learned) ================= -->
            <!-- ClipToBounds is insurance, not a crop: RadarLayout.CanvasWidth is
                 sized so nothing can land outside. It's here so a rounding edge case
                 can't paint a car over the glows, which are furniture, not track. -->
            <Grid Width="{x:Static vm:RadarLayout.CanvasWidth}"
                  Height="{x:Static vm:RadarLayout.CanvasHeight}"
                  ClipToBounds="True"
                  Visibility="{Binding ShowRadar, Converter={StaticResource BoolToVis}}">

                <!-- The one piece of furniture: a dashed line level with your axles,
                     so overlap is judged against something instead of guessed. A
                     Rectangle rather than a Path so it spans whatever the canvas
                     width is, instead of restating it as a magic number. -->
                <Rectangle Height="1"
                           Stroke="#59FFFFFF" StrokeThickness="1" StrokeDashArray="3 4"
                           VerticalAlignment="Center" HorizontalAlignment="Stretch" />

                <!-- Other cars, absolutely positioned on a Canvas by the view model -->
                <ItemsControl ItemsSource="{Binding Blips}"
                              Width="{x:Static vm:RadarLayout.CanvasWidth}"
                              Height="{x:Static vm:RadarLayout.CanvasHeight}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}" />
                            <Setter Property="Canvas.Top" Value="{Binding CanvasTop}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="{x:Static vm:RadarLayout.BlipWidth}"
                                    Height="{x:Static vm:RadarLayout.BlipHeight}"
                                    CornerRadius="2"
                                    Background="#FFF2F4F7"
                                    RenderTransformOrigin="0.5,0.5"
                                    Opacity="{Binding Opacity}">
                                <!-- A soft dark halo instead of a hard border: keeps a pale
                                     car legible against sky or kerbs without drawing a box. -->
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="6" ShadowDepth="0"
                                                      Opacity="0.85" Color="#000000" />
                                </Border.Effect>
                                <Border.RenderTransform>
                                    <RotateTransform Angle="{Binding AngleDegrees}" />
                                </Border.RenderTransform>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- Your car: dead centre, facing up, green so it never reads as traffic.
                 Lives outside the canvas so the first-lap spotter fallback - glow only,
                 no positions - still has something to be centred on. -->
            <Border Width="{x:Static vm:RadarLayout.BlipWidth}"
                    Height="{x:Static vm:RadarLayout.BlipHeight}"
                    CornerRadius="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#FF37D14A"
                    Visibility="{Binding ShowCar, Converter={StaticResource BoolToVis}}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.85" Color="#000000" />
                </Border.Effect>
            </Border>

            <!-- ================= Placeholder (pre-session) ================= -->
            <TextBlock Text="radar"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="{StaticResource TextMuted}"
                       Visibility="{Binding IsWaitingForData, Converter={StaticResource BoolToVis}}" />
        </Grid>
    </Grid>
</Window>
