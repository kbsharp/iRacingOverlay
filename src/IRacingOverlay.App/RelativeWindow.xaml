<Window x:Class="IRacingOverlay.App.RelativeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iRacing Overlay - Relative"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="24"
        Top="760"
        FontFamily="{StaticResource FontText}"
        MouseLeftButtonDown="OnDragWindow">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Margin="14">
        <Border Width="470"
                Padding="14,9,14,10"
                CornerRadius="6"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1"
                ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.6" Color="#000000" />
            </Border.Effect>
            <StackPanel>

                <!-- session strip: session/time/lap · flag | brake bias · temps · wetness · incidents

                     A Grid, not a DockPanel, and deliberately so. Under a DockPanel
                     the left-docked tokens claimed width first and the right-hand
                     telemetry group - being the last child - was left with whatever
                     remained, which at 470px was routinely nothing: the group
                     collapsed to zero width and drew straight over the flag chip.
                     Adding one more chip to the left made it worse, so every future
                     chip would have re-broken it. Here the right group sits in an
                     Auto column, which Grid measures *before* the star column, so it
                     always reserves its real width; the left group takes the
                     remainder and the session label (below) absorbs the squeeze. -->
                <Grid Margin="0,0,0,7">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <!-- trailing spacer: keeps the tokens packed left rather than
                                 letting a star column push them toward the middle. -->
                            <ColumnDefinition Width="*" MinWidth="0" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource Warning}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource Positive}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <!-- No session-type label here, unlike the standings. This strip
                             cannot fit one: with the flag chip, the projected-iRating
                             chip, brake bias, both temps, wetness and incidents all up,
                             470px is already full, and every attempt to make the label
                             yield was worse than omitting it - trimming renders a ".."
                             stub that costs width and says nothing, and a capped star
                             column shoves the whole strip toward the middle whenever the
                             label is short. The information is not lost: the standings
                             carries the session type, and the flag chip beside the clock
                             carries the race state that actually changes what you do. -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SessionRemainingText}"
                                   Margin="9,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Typography.NumeralAlignment="Tabular"
                                   Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding LapCounterText}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Typography.NumeralAlignment="Tabular"
                                   Foreground="{StaticResource TextSecondary}" />
                        <Border Grid.Column="3"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Style="{StaticResource FlagChipBackground}"
                                Visibility="{Binding HasFlag, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding FlagText}" Style="{StaticResource FlagChipText}" />
                        </Border>
                        <!-- projected iRating: arrow + points at stake, hidden until a
                             racing lap is complete and captured once the flag is out. -->
                        <Border Grid.Column="4"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                DataContext="{Binding IRating}"
                                Style="{StaticResource RatingDeltaChipBackground}"
                                Visibility="{Binding HasValue, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Arrow}" Style="{StaticResource RatingDeltaChipText}" />
                                <TextBlock Text="{Binding DeltaText}"
                                           Margin="3,0,0,0"
                                           Style="{StaticResource RatingDeltaChipText}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- VerticalAlignment on the group, not on its children: a
                         horizontal StackPanel stretches its children to full height,
                         so the centred brake glyph and the top-rendered text beside
                         it disagreed by a couple of pixels. Centring the group keeps
                         glyph and text on one line. -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- brake bias, marked with a disc rather than a "BB" prefix:
                             the glyph is read at a glance where two letters aren't. -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding HasBrakeBias, Converter={StaticResource BoolToVis}}">
                            <Path Style="{StaticResource BrakeDiscMark}" />
                            <TextBlock Text="{Binding BrakeBiasText}"
                                       Margin="4,0,0,0"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource Caption}"
                                       Typography.NumeralAlignment="Tabular" />
                        </StackPanel>
                        <TextBlock Text="{Binding TrackTempText}" Margin="10,0,0,0" VerticalAlignment="Center" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding AirTempText}" Margin="10,0,0,0" VerticalAlignment="Center" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding WetnessText}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Warning}"
                                   Visibility="{Binding IsWet, Converter={StaticResource BoolToVis}}" />
                        <!-- incidents warm to amber then red as the licence limit
                             nears, so it's a signal rather than a static number. -->
                        <TextBlock Text="{Binding IncidentsText}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Typography.NumeralAlignment="Tabular">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource Caption}">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IncidentLevel}" Value="Warning">
                                            <Setter Property="Foreground" Value="{StaticResource Warning}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IncidentLevel}" Value="Critical">
                                            <Setter Property="Foreground" Value="{StaticResource Negative}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <Border Height="1" Background="{StaticResource Separator}" Margin="0,0,0,3" />

                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Height="24">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Setter Property="CornerRadius" Value="3" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAltRow}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource RowStripe}" />
                                            </DataTrigger>
                                            <!-- "You" row: warm wash + a warm outer glow so it reads as
                                                 lit, not just tinted - the single most important row to
                                                 find at a glance. -->
                                            <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource PlayerHighlight}" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="16" ShadowDepth="0"
                                                                          Color="{StaticResource PlayerGlowColor}" Opacity="0.5" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                <Setter Property="Visibility" Value="Hidden" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid VerticalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="42" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>

                                    <!-- full-height class colour bar, flush to the panel edge -->
                                    <Border Grid.Column="0" Width="5" Margin="-14,0,0,0"
                                            Background="{Binding ClassColorBrush}" />

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PositionText}"
                                               VerticalAlignment="Center"
                                               Margin="3,0,0,0"
                                               FontFamily="{StaticResource FontSmall}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Typography.NumeralAlignment="Tabular"
                                               Foreground="{StaticResource TextMuted}" />

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding CarNumberText}"
                                               VerticalAlignment="Center"
                                               FontFamily="{StaticResource FontSmall}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Typography.NumeralAlignment="Tabular"
                                               Foreground="{StaticResource TextSecondary}" />

                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Margin="0,0,6,0"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LapDifference}" Value="LapAhead">
                                                        <Setter Property="Foreground" Value="{StaticResource LapAheadText}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding LapDifference}" Value="LapBehind">
                                                        <Setter Property="Foreground" Value="{StaticResource LapBehindText}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding InPits}" Value="True">
                                                        <Setter Property="Opacity" Value="0.5" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Border Grid.Column="4" Style="{StaticResource LicenseBadgeBackground}">
                                        <TextBlock Text="{Binding License}"
                                                   Style="{StaticResource LicenseBadgeText}" />
                                    </Border>

                                    <Border Grid.Column="5" Style="{StaticResource IRatingBadgeBackground}">
                                        <TextBlock Text="{Binding IRatingText}"
                                                   Style="{StaticResource IRatingBadgeText}" />
                                    </Border>

                                    <!-- 8px, not 2: on the player row the amber wash draws a
                                         real edge here, and the delta sat all but touching
                                         it. On a transparent row the old 2px was invisible. -->
                                    <StackPanel Grid.Column="6"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0">
                                        <Border Margin="0,0,6,0"
                                                Style="{StaticResource PitBadgeBackground}"
                                                Visibility="{Binding InPits, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="PIT" Style="{StaticResource PitBadgeText}" />
                                        </Border>
                                        <!-- The delta is the widget's reason to exist - the one
                                             number read at 200kph - so it is the largest, heaviest
                                             thing in the row and everything else steps down behind
                                             it. At the old 13 it tied with the driver name and the
                                             eye had nowhere to land. -->
                                        <TextBlock Text="{Binding DeltaText}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Typography.NumeralAlignment="Tabular"
                                                   Foreground="{StaticResource TextPrimary}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>
    </Grid>
</Window>
