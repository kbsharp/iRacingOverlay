<Window x:Class="IRacingOverlay.App.RelativeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iRacing Overlay - Relative"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="24"
        Top="760"
        FontFamily="{StaticResource FontText}"
        MouseLeftButtonDown="OnDragWindow">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Margin="14">
        <Border Width="470"
                Padding="14,9,14,10"
                CornerRadius="3"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1"
                ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.6" Color="#000000" />
            </Border.Effect>
            <StackPanel>

                <!-- session strip: session/time · brake bias · temps · wetness · incidents -->
                <DockPanel Margin="0,0,0,7">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" DockPanel.Dock="Left">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource Warning}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource Positive}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding SessionText}"
                               Margin="9,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding BrakeBiasText}"
                                   Margin="10,0,0,0"
                                   Style="{StaticResource Caption}"
                                   Visibility="{Binding HasBrakeBias, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding TrackTempText}" Margin="10,0,0,0" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding AirTempText}" Margin="10,0,0,0" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding WetnessText}"
                                   Margin="10,0,0,0"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Warning}"
                                   Visibility="{Binding IsWet, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding IncidentsText}"
                                   Margin="10,0,0,0"
                                   Style="{StaticResource Caption}"
                                   Foreground="{StaticResource TextSecondary}" />
                    </StackPanel>
                </DockPanel>

                <Border Height="1" Background="{StaticResource Separator}" Margin="0,0,0,3" />

                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Height="24">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAltRow}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource RowStripe}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource PlayerHighlight}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                <Setter Property="Visibility" Value="Hidden" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid VerticalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="42" />
                                        <ColumnDefinition Width="62" />
                                    </Grid.ColumnDefinitions>

                                    <!-- full-height class colour bar, flush to the panel edge -->
                                    <Border Grid.Column="0" Width="5" Margin="-14,0,0,0"
                                            Background="{Binding ClassColorBrush}" />

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PositionText}"
                                               VerticalAlignment="Center"
                                               Margin="3,0,0,0"
                                               FontFamily="{StaticResource FontSmall}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Typography.NumeralAlignment="Tabular"
                                               Foreground="{StaticResource TextMuted}" />

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding CarNumberText}"
                                               VerticalAlignment="Center"
                                               FontFamily="{StaticResource FontSmall}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Typography.NumeralAlignment="Tabular"
                                               Foreground="{StaticResource TextSecondary}" />

                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Margin="0,0,6,0"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LapDifference}" Value="LapAhead">
                                                        <Setter Property="Foreground" Value="{StaticResource LapAheadText}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding LapDifference}" Value="LapBehind">
                                                        <Setter Property="Foreground" Value="{StaticResource LapBehindText}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding InPits}" Value="True">
                                                        <Setter Property="Opacity" Value="0.5" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Border Grid.Column="4"
                                            CornerRadius="2"
                                            Padding="4,1"
                                            Height="16"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource LicenseBadgeBackground}">
                                        <TextBlock Text="{Binding License}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Style="{StaticResource LicenseBadgeText}" />
                                    </Border>

                                    <Border Grid.Column="5"
                                            CornerRadius="2"
                                            Padding="4,1"
                                            Height="16"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource IRatingBadgeBackground}">
                                        <TextBlock Text="{Binding IRatingText}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Style="{StaticResource IRatingBadgeText}" />
                                    </Border>

                                    <StackPanel Grid.Column="6"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,0,2,0">
                                        <Border CornerRadius="2"
                                                Padding="4,1"
                                                Margin="0,0,6,0"
                                                Background="#3DFFB03D"
                                                BorderBrush="#8AFFB03D"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding InPits, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="PIT"
                                                       FontFamily="{StaticResource FontSmall}"
                                                       FontSize="9"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource Warning}" />
                                        </Border>
                                        <TextBlock Text="{Binding DeltaText}"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Typography.NumeralAlignment="Tabular"
                                                   Foreground="{StaticResource TextPrimary}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>
    </Grid>
</Window>
