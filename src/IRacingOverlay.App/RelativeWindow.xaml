<Window x:Class="IRacingOverlay.App.RelativeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iRacing Overlay - Relative"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="24"
        Top="760"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        MouseLeftButtonDown="OnDragWindow">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Margin="16">
    <Border Width="468"
            Padding="16,10,16,12"
            CornerRadius="14"
            Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource PanelBorder}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.6" Color="#000000" />
        </Border.Effect>
        <Grid>
        <Border CornerRadius="14" Margin="-16,-10,-16,-12" Background="{StaticResource PanelSheen}" IsHitTestVisible="False" />
        <StackPanel>

            <!-- header -->
            <DockPanel Margin="0,0,0,8">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center" DockPanel.Dock="Left">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource Warning}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource Positive}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding ConnectionStatus}"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Style="{StaticResource Caption}" />
                <TextBlock Text="RELATIVE"
                           Margin="9,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="{StaticResource Accent}" />
            </DockPanel>

            <!-- session strip: session/time · brake bias · temps · wetness · incidents -->
            <DockPanel Margin="0,0,0,8">
                <TextBlock Text="{Binding SessionText}"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding BrakeBiasText}"
                               Margin="10,0,0,0"
                               Style="{StaticResource Caption}"
                               Visibility="{Binding HasBrakeBias, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding TrackTempText}" Margin="10,0,0,0" Style="{StaticResource Caption}" />
                    <TextBlock Text="{Binding AirTempText}" Margin="10,0,0,0" Style="{StaticResource Caption}" />
                    <Border Margin="10,0,0,0"
                            CornerRadius="5"
                            Padding="6,1"
                            Background="#26FFC24D"
                            Visibility="{Binding IsWet, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding WetnessText}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Warning}" />
                    </Border>
                    <TextBlock Text="{Binding IncidentsText}"
                               Margin="10,0,0,0"
                               Style="{StaticResource Caption}"
                               Foreground="{StaticResource TextSecondary}" />
                </StackPanel>
            </DockPanel>

            <Border Height="1" Background="{StaticResource Separator}" Margin="0,0,0,4" />

            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Height="26" CornerRadius="7" Margin="0,1" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PlayerHighlight}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource PlayerBorder}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                            <Setter Property="Visibility" Value="Hidden" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="26" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>

                                <!-- class colour bar - straight from the sim's own CarClassColor -->
                                <Border Grid.Column="0"
                                        Width="4"
                                        Margin="-16,3,0,3"
                                        CornerRadius="2,0,0,2"
                                        Background="{Binding ClassColorBrush}" />

                                <TextBlock Grid.Column="1"
                                           Text="{Binding PositionText}"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource TextMuted}" />

                                <TextBlock Grid.Column="2"
                                           Text="{Binding CarNumberText}"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}" />

                                <TextBlock Grid.Column="3"
                                           Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Margin="0,0,6,0"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LapDifference}" Value="LapAhead">
                                                    <Setter Property="Foreground" Value="{StaticResource LapAheadText}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LapDifference}" Value="LapBehind">
                                                    <Setter Property="Foreground" Value="{StaticResource LapBehindText}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding InPits}" Value="True">
                                                    <Setter Property="Opacity" Value="0.5" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <StackPanel Grid.Column="4"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,3,0">
                                    <Border CornerRadius="4"
                                            Padding="5,1"
                                            Margin="0,0,6,0"
                                            Background="#26FFC24D"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding InPits, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="PIT"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource Warning}" />
                                    </Border>
                                    <TextBlock Text="{Binding DeltaText}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
        </Grid>
    </Border>
    <Border Height="1"
            Margin="1,1,1,0"
            CornerRadius="14,14,0,0"
            VerticalAlignment="Top"
            Background="{StaticResource PanelTopHighlight}"
            IsHitTestVisible="False" />
    </Grid>
</Window>
