<Window x:Class="IRacingOverlay.App.RelativeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iRacing Overlay - Relative"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        MouseLeftButtonDown="OnDragWindow">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="OnExit" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Margin="16">
    <Border Width="640"
            Padding="20,14,20,16"
            CornerRadius="16"
            Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource PanelBorder}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.55" Color="#000000" />
        </Border.Effect>
        <StackPanel>

            <!-- header -->
            <DockPanel Margin="0,0,0,10">
                <Ellipse Width="9" Height="9" VerticalAlignment="Center" DockPanel.Dock="Left">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource Warning}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource Positive}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding ConnectionStatus}"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Style="{StaticResource Caption}" />
                <TextBlock Text="RELATIVE"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="{StaticResource Accent}" />
            </DockPanel>

            <!-- session strip: session/time · brake bias · temps · wetness · incidents -->
            <DockPanel Margin="0,0,0,10">
                <TextBlock Text="{Binding SessionText}"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding BrakeBiasText}"
                               Margin="12,0,0,0"
                               Style="{StaticResource Caption}"
                               Visibility="{Binding HasBrakeBias, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding TrackTempText}" Margin="12,0,0,0" Style="{StaticResource Caption}" />
                    <TextBlock Text="{Binding AirTempText}" Margin="12,0,0,0" Style="{StaticResource Caption}" />
                    <Border Margin="12,0,0,0"
                            CornerRadius="5"
                            Padding="6,2"
                            Background="#26FFC24D"
                            Visibility="{Binding IsWet, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding WetnessText}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Warning}" />
                    </Border>
                    <TextBlock Text="{Binding IncidentsText}"
                               Margin="12,0,0,0"
                               Style="{StaticResource Caption}"
                               Foreground="{StaticResource TextSecondary}" />
                </StackPanel>
            </DockPanel>

            <Border Height="1" Background="{StaticResource Separator}" Margin="0,0,0,6" />

            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Height="34" CornerRadius="8" Margin="0,1" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PlayerHighlight}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource PlayerBorder}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                            <Setter Property="Visibility" Value="Hidden" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="46" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="58" />
                                    <ColumnDefinition Width="58" />
                                    <ColumnDefinition Width="92" />
                                </Grid.ColumnDefinitions>

                                <!-- class colour bar - straight from the sim's own CarClassColor -->
                                <Border Grid.Column="0"
                                        Width="4"
                                        Margin="-20,4,0,4"
                                        CornerRadius="2,0,0,2"
                                        Background="{Binding ClassColorBrush}" />

                                <TextBlock Grid.Column="1"
                                           Text="{Binding PositionText}"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"
                                           FontSize="13"
                                           Foreground="{StaticResource TextMuted}" />

                                <TextBlock Grid.Column="2"
                                           Text="{Binding CarNumberText}"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}" />

                                <TextBlock Grid.Column="3"
                                           Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,6,0"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LapDifference}" Value="LapAhead">
                                                    <Setter Property="Foreground" Value="{StaticResource LapAheadText}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LapDifference}" Value="LapBehind">
                                                    <Setter Property="Foreground" Value="{StaticResource LapBehindText}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding InPits}" Value="True">
                                                    <Setter Property="Opacity" Value="0.5" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- license badge: coloured per iRacing's own license classes -->
                                <Border Grid.Column="4"
                                        CornerRadius="5"
                                        Padding="5,2"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource LicenseBadgeBackground}">
                                    <TextBlock Text="{Binding License}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Style="{StaticResource LicenseBadgeText}" />
                                </Border>

                                <!-- iRating badge: coloured by rating band -->
                                <Border Grid.Column="5"
                                        CornerRadius="5"
                                        Padding="5,2"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource IRatingBadgeBackground}">
                                    <TextBlock Text="{Binding IRatingText}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Style="{StaticResource IRatingBadgeText}" />
                                </Border>

                                <StackPanel Grid.Column="6"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,4,0">
                                    <Border CornerRadius="4"
                                            Padding="5,1"
                                            Margin="0,0,7,0"
                                            Background="#26FFC24D"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding InPits, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="PIT"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource Warning}" />
                                    </Border>
                                    <TextBlock Text="{Binding DeltaText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
    <Border Height="1"
            Margin="1,1,1,0"
            CornerRadius="16,16,0,0"
            VerticalAlignment="Top"
            Background="{StaticResource PanelTopHighlight}"
            IsHitTestVisible="False" />
    </Grid>
</Window>
